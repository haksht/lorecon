// Enhanced device tracking for reconnaissance
struct ReconDevice {
  uint32_t nodeId;
  uint8_t configIndex;      // Which scan config detected this device
  float bestRSSI;
  float avgRSSI;
  uint16_t detectionCount;  // How many times we've detected activity
  uint32_t lastSeen;
  uint32_t firstSeen;
  char protocol[16];
  char deviceType[24];      // Identified device type
  char firmwareVersion[16]; // Detected firmware version if available
  bool hasCapturedPacket;   // Whether we've successfully captured a full packet
  bool isRouter;            // Device appears to be routing traffic
  uint8_t powerClass;       // Estimated power class (0=low, 1=med, 2=high)
};

ReconDevice reconDevices[MAX_TRACKED_NODES];
uint8_t numReconDevices = 0;

