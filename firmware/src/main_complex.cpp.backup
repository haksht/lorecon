// Interrupt handler for packet reception
volatile bool packetReceived = false;
void IRAM_ATTR onPacketReceived() {
  packetReceived = true;
}

// Apply radio configuration for scanning
bool applyConfig(uint8_t configIndex) {
  if (configIndex >= NUM_CONFIGS) return false;
  
  const ScanConfig& cfg = scanConfigs[configIndex];
  
  Serial.printf("[SCAN] %s (%.3f MHz, SF%d, BW%.0f, SW:0x%02X)\n", 
                cfg.protocol, cfg.frequency, cfg.spreadingFactor, 
                cfg.bandwidth, cfg.syncWord);
  
  // Apply configuration with error checking
  int state = radio.setFrequency(cfg.frequency);
  if (state != RADIOLIB_ERR_NONE) return false;
  
  state = radio.setBandwidth(cfg.bandwidth);
  if (state != RADIOLIB_ERR_NONE) return false;
  
  state = radio.setSpreadingFactor(cfg.spreadingFactor);
  if (state != RADIOLIB_ERR_NONE) return false;
  
  state = radio.setSyncWord(cfg.syncWord);
  if (state != RADIOLIB_ERR_NONE) return false;
  
  // Try different parameters based on protocol type
  if (strstr(cfg.protocol, "Meshtastic_MSG") != nullptr) {
    radio.setCodingRate(5);         // 4/5 for message content
    radio.setPreambleLength(8);     // Standard for messages
    radio.setCRC(true);             // Enable CRC for message integrity
  } else if (strstr(cfg.protocol, "Meshtastic_MF") != nullptr) {
    radio.setCodingRate(8);         // 4/8 for MediumFast
    radio.setPreambleLength(12);    // Longer preamble
    radio.setCRC(false);            // Promiscuous mode
  } else {
    radio.setCodingRate(5);         // 4/5 for routing packets
    radio.setPreambleLength(8);     // Standard
    radio.setCRC(false);            // Promiscuous mode
  }
  radio.setCRC(false);              // Promiscuous mode
  radio.explicitHeader();
  
  // Receive-only mode (no transmission)
  radio.setCurrentLimit(100);
  radio.setOutputPower(0);
  
  return true;
}

// Protocol identification based on packet analysis
const char* identifyProtocol(const uint8_t* data, size_t length) {
  if (length < 4) return "Short";
  
  // Meshtastic signature detection
  if (data[0] == 0xFF && data[1] == 0xFF && data[2] == 0xFF && data[3] == 0xFF) {
    return "Meshtastic";
  }
  
  // TTN/LoRaWAN detection (simplified)
  if (length >= 12 && length <= 51) {
    uint8_t mtype = (data[0] >> 5) & 0x07;
    if (mtype >= 0x00 && mtype <= 0x07) {
      return "LoRaWAN";
    }
  }
  
  // Short packets might be beacons or keep-alives
  if (length <= 8) return "Beacon";
  
  return "Unknown";
}

// Device type identification based on packet patterns and characteristics
const char* identifyDeviceType(const uint8_t* data, size_t length, const char* protocol, float rssi) {
  // Meshtastic device type detection
  if (strcmp(protocol, "Meshtastic") == 0) {
    // High power, likely base station or solar powered
    if (rssi > -50) return "Meshtastic Base/Solar";
    
    // Check for routing patterns in payload
    if (length >= 16) {
      uint8_t hopCount = data[8] & 0x07;  // Hop count in routing header
      if (hopCount > 0) return "Meshtastic Router";
    }
    
    // Power class estimation based on RSSI and packet patterns
    if (rssi > -80) return "Meshtastic Mobile";
    if (rssi > -110) return "Meshtastic Handheld";
    return "Meshtastic Low-Power";
  }
  
  // LoRaWAN device classification
  if (strcmp(protocol, "LoRaWAN") == 0) {
    uint8_t mtype = (data[0] >> 5) & 0x07;
    
    switch (mtype) {
      case 0x00: return "LoRaWAN Join Request";
      case 0x01: return "LoRaWAN Join Accept";
      case 0x02: return "LoRaWAN Unconfirmed Up";
      case 0x03: return "LoRaWAN Unconfirmed Down";
      case 0x04: return "LoRaWAN Confirmed Up";
      case 0x05: return "LoRaWAN Confirmed Down";
      case 0x06: return "LoRaWAN RejoinReq";
      case 0x07: return "LoRaWAN Proprietary";
    }
  }
  
  // Beacon analysis
  if (strcmp(protocol, "Beacon") == 0) {
    if (rssi > -60) return "Beacon High-Power";
    return "Beacon Standard";
  }
  
  return "Unknown Device";
}

// Estimate power class based on RSSI patterns
uint8_t estimatePowerClass(float rssi) {
  if (rssi > -70) return 2;  // High power (>100mW)
  if (rssi > -90) return 1;  // Medium power (10-100mW)
  return 0;                  // Low power (<10mW)
}

// Check if device appears to be routing traffic
bool isRoutingDevice(const uint8_t* data, size_t length, const char* protocol) {
  if (strcmp(protocol, "Meshtastic") == 0 && length >= 12) {
    uint8_t hopCount = data[8] & 0x07;
    uint8_t routingFlags = data[9];
    return (hopCount > 0 || (routingFlags & 0x01)); // Has hops or routing flag set
  }
  return false;
}

// Extract node ID from packet (protocol-dependent)
uint32_t extractNodeId(const uint8_t* data, size_t length, const char* protocol) {
  if (strcmp(protocol, "Meshtastic") == 0 && length >= 8) {
    // Meshtastic node ID typically at offset 4-7
    return (uint32_t(data[4]) << 24) | (uint32_t(data[5]) << 16) | 
           (uint32_t(data[6]) << 8) | uint32_t(data[7]);
  }
  
  if (strcmp(protocol, "LoRaWAN") == 0 && length >= 8) {
    // LoRaWAN DevAddr at offset 1-4 (little endian)
    return uint32_t(data[1]) | (uint32_t(data[2]) << 8) | 
           (uint32_t(data[3]) << 16) | (uint32_t(data[4]) << 24);
  }
  
  return 0;
}

// Update node tracking database
void trackNode(uint32_t nodeId, const char* protocol, float rssi) {
  if (nodeId == 0) return;
  
  // Find existing node or create new entry
  TrackedNode* node = nullptr;
  for (uint8_t i = 0; i < nodeCount; i++) {
    if (trackedNodes[i].nodeId == nodeId) {
      node = &trackedNodes[i];
      break;
    }
  }
  
  if (!node && nodeCount < MAX_TRACKED_NODES) {
    node = &trackedNodes[nodeCount++];
    node->nodeId = nodeId;
    node->protocol = protocol;
    node->packetCount = 0;
    node->avgRSSI = rssi;
    node->bestRSSI = rssi;
    node->firstSeen = millis();
    Serial.printf("[NODE] New: 0x%08X (%s)\n", nodeId, protocol);
  }
  
  if (node) {
    node->packetCount++;
    node->avgRSSI = (node->avgRSSI * (node->packetCount - 1) + rssi) / node->packetCount;
    if (rssi > node->bestRSSI) node->bestRSSI = rssi;
    node->lastSeen = millis();
    node->active = true;
  }
}

// Reconnaissance device tracking with device type identification
void trackReconDevice(uint8_t configIndex, float rssi, bool hasPacket = false, uint32_t nodeId = 0, const char* protocol = "Unknown", const uint8_t* packetData = nullptr, size_t packetLength = 0) {
  // Enhanced device deduplication - find existing device by multiple criteria
  ReconDevice* device = nullptr;
  
  // First priority: Match by actual node ID if we have one
  if (nodeId != 0) {
    for (uint8_t i = 0; i < numReconDevices; i++) {
      if (reconDevices[i].nodeId == nodeId) {
        device = &reconDevices[i];
        // Update config if this is a better one (has packets)
        if (hasPacket && !reconDevices[i].hasCapturedPacket) {
          reconDevices[i].configIndex = configIndex;
        }
        break;
      }
    }
  }
  
  // Second priority: Match by config and signal characteristics (for signal-only detections)
  if (!device) {
    for (uint8_t i = 0; i < numReconDevices; i++) {
      if (reconDevices[i].configIndex == configIndex && 
          reconDevices[i].nodeId == 0 && nodeId == 0 &&
          abs(reconDevices[i].bestRSSI - rssi) < 20.0) {  // Similar signal strength
        device = &reconDevices[i];
        break;
      }
    }
  }
  
  // Create new device entry
  if (!device && numReconDevices < MAX_TRACKED_NODES) {
    device = &reconDevices[numReconDevices++];
    device->configIndex = configIndex;
    device->nodeId = nodeId;
    device->detectionCount = 0;
    device->avgRSSI = rssi;
    device->bestRSSI = rssi;
    device->firstSeen = millis();
    device->hasCapturedPacket = hasPacket;
    device->powerClass = estimatePowerClass(rssi);
    device->isRouter = false;
    
    strncpy(device->protocol, protocol, sizeof(device->protocol) - 1);
    device->protocol[sizeof(device->protocol) - 1] = '\0';
    
    // Initialize device type and firmware version
    strcpy(device->deviceType, "Unknown Device");
    strcpy(device->firmwareVersion, "Unknown");
    
    // Perform device type identification 
    if (packetData && packetLength > 0) {
      const char* detectedType = identifyDeviceType(packetData, packetLength, protocol, rssi);
      strncpy(device->deviceType, detectedType, sizeof(device->deviceType) - 1);
      device->deviceType[sizeof(device->deviceType) - 1] = '\0';
      device->isRouter = isRoutingDevice(packetData, packetLength, protocol);
    } else {
      // Signal-only detection - classify by RSSI and protocol
      if (strstr(protocol, "Meshtastic") != nullptr) {
        if (rssi > -50) {
          strcpy(device->deviceType, "Meshtastic Base/Solar");
        } else if (rssi > -80) {
          strcpy(device->deviceType, "Meshtastic Mobile");
        } else if (rssi > -110) {
          strcpy(device->deviceType, "Meshtastic Handheld");
        } else {
          strcpy(device->deviceType, "Meshtastic Low-Power");
        }
      } else if (strstr(protocol, "LoRaWAN") != nullptr || strstr(protocol, "TTN") != nullptr) {
        strcpy(device->deviceType, "LoRaWAN Device");
      } else {
        strcpy(device->deviceType, "Signal Source");
      }
    }
    
    if (hasPacket && nodeId != 0) {
      Serial.printf("[RECON] New device: 0x%08X (%s) on %s (%.1f dBm)\n", 
                    nodeId, device->deviceType, scanConfigs[configIndex].protocol, rssi);
    } else if (nodeId != 0) {
      Serial.printf("[RECON] Signal source: 0x%08X (%s) on %s (%.1f dBm) - TARGETABLE\n", 
                    nodeId, device->deviceType, scanConfigs[configIndex].protocol, rssi);
    } else {
      Serial.printf("[RECON] Activity detected: %s on %s (%.1f dBm)\n", 
                    device->deviceType, scanConfigs[configIndex].protocol, rssi);
    }
  }
  
  if (device) {
    device->detectionCount++;
    device->avgRSSI = (device->avgRSSI * (device->detectionCount - 1) + rssi) / device->detectionCount;
    if (rssi > device->bestRSSI) device->bestRSSI = rssi;
    device->lastSeen = millis();
    if (hasPacket) device->hasCapturedPacket = true;
    if (nodeId != 0 && device->nodeId == 0) device->nodeId = nodeId;
  }
}

// Show reconnaissance results and interactive menu
// Display device type analysis summary
void showDeviceTypeSummary() {
  Serial.println("\nDEVICE TYPE ANALYSIS:");
  Serial.println("Type                    | Count | Avg RSSI | Routers | Power Class");
  Serial.println("------------------------|-------|----------|---------|------------");
  
  // Count device types
  struct DeviceTypeStat {
    char type[24];
    uint8_t count;
    float totalRSSI;
    uint8_t routers;
    uint8_t powerClassSum;
  } typeStats[20];
  uint8_t numTypes = 0;
  
  for (uint8_t i = 0; i < numReconDevices; i++) {
    ReconDevice& dev = reconDevices[i];
    
    // Find existing type or create new
    DeviceTypeStat* stat = nullptr;
    for (uint8_t j = 0; j < numTypes; j++) {
      if (strcmp(typeStats[j].type, dev.deviceType) == 0) {
        stat = &typeStats[j];
        break;
      }
    }
    
    if (!stat && numTypes < 20) {
      stat = &typeStats[numTypes++];
      strcpy(stat->type, dev.deviceType);
      stat->count = 0;
      stat->totalRSSI = 0;
      stat->routers = 0;
      stat->powerClassSum = 0;
    }
    
    if (stat) {
      stat->count++;
      stat->totalRSSI += dev.avgRSSI;
      if (dev.isRouter) stat->routers++;
      stat->powerClassSum += dev.powerClass;
    }
  }
  
  // Display type statistics
  for (uint8_t i = 0; i < numTypes; i++) {
    DeviceTypeStat& stat = typeStats[i];
    float avgRSSI = stat.totalRSSI / stat.count;
    float avgPowerClass = (float)stat.powerClassSum / stat.count;
    const char* powerDesc = avgPowerClass > 1.5 ? "High" : (avgPowerClass > 0.5 ? "Medium" : "Low");
    
    Serial.printf("%-23s | %5d | %8.1f | %7d | %s\n",
                  stat.type, stat.count, avgRSSI, stat.routers, powerDesc);
  }
}

void showReconResults() {
  Serial.println("\n" + String('=').substring(0,50));
  Serial.println("         RECONNAISSANCE COMPLETE");
  Serial.println(String('=').substring(0,50));
  
  uint32_t reconTime = (millis() - scanState.reconStartTime) / 1000;
  Serial.printf("Scan Duration: %lu seconds\n", reconTime);
  Serial.printf("Total Detections: %d\n", scanState.totalDetections);
  Serial.printf("Devices Found: %d\n", numReconDevices);
  Serial.println();
  
  if (numReconDevices == 0) {
    Serial.println("No devices detected. Press 'r' to restart reconnaissance.");
    return;
  }
  
  // Show device type analysis
  showDeviceTypeSummary();
  
  Serial.println("\nDETAILED DEVICE LIST:");
  Serial.println("ID | Device Type          | Node ID    | RSSI  | Pkts | Router | Age");
  Serial.println("---|----------------------|------------|-------|------|--------|------");
  
  for (uint8_t i = 0; i < numReconDevices; i++) {
    ReconDevice& dev = reconDevices[i];
    uint32_t ageSeconds = (millis() - dev.lastSeen) / 1000;
    
    Serial.printf("%2d | %-20s | 0x%08X | %5.1f | %4d | %s | %4lus\n",
                  i + 1,
                  dev.deviceType,
                  dev.nodeId,
                  dev.bestRSSI,
                  dev.detectionCount,
                  dev.isRouter ? "  YES " : "  NO  ",
                  ageSeconds);
  }
  
  Serial.println("\nCOMMANDS:");
  Serial.println("1-" + String(numReconDevices) + " : Target device for capture");
  Serial.println("d   : Show device type analysis");
  Serial.println("r   : Restart reconnaissance");
  Serial.println("s   : Show summary again");
#ifdef ENABLE_STRESS_TESTING
  Serial.println("t   : Hardware stress testing");
#endif
#ifdef ENABLE_INTELLIGENCE_STORAGE
  Serial.println("i   : Intelligence analysis");
#endif
  Serial.print("\nSelect target (1-" + String(numReconDevices) + ") or command: ");
}

#ifdef ENABLE_PSK_TESTING
// Base64 decode helper
bool decodeBase64(const char* input, uint8_t* output, size_t maxLen) {
  size_t outLen;
  int result = mbedtls_base64_decode(output, maxLen, &outLen, 
                                    (const unsigned char*)input, strlen(input));
  return (result == 0 && outLen > 0);
}

// Attempt packet decryption with known PSKs
bool testDefaultPSKs(const uint8_t* data, size_t length) {
  pskStats.attempts++;
  
  // Declare variables at function scope to avoid scope issues
  bool isTextMessage = false;
  String messageText = "";
  
  // Enhanced Meshtastic message analysis
  if (length >= 8) {
    Serial.println("[PSK] === MESHTASTIC MESSAGE ANALYSIS ===");
    
    // Meshtastic packet structure analysis
    Serial.printf("[PSK] Header: %02X %02X %02X %02X (signature)\n", data[0], data[1], data[2], data[3]);
    Serial.printf("[PSK] Node ID: 0x%08X\n", (uint32_t(data[4]) << 24) | (uint32_t(data[5]) << 16) | (uint32_t(data[6]) << 8) | uint32_t(data[7]));
    
    if (length > 8) {
      Serial.printf("[PSK] Message Type: 0x%02X\n", data[8]);
      
      // Enhanced text message detection - look for longer, meaningful text
      // Skip the obvious routing patterns and look for actual user content
      
      // Enhanced message type detection
      uint8_t msgType = data[8];
      
      // Routing/control message patterns (expand detection)
      bool isRoutingPattern = (length <= 16 && 
                               ((msgType >= 0x0A && msgType <= 0x3F) || // Expanded routing range
                                (data[length-2] == 0x63 && data[length-1] == 0x66) || // Common suffix
                                (msgType >= 0xF0))); // High-range control messages
      
      // User message type indicators (common Meshtastic user message types)
      bool isPotentialUserMessage = (msgType == 0x00 || msgType == 0x01 || // Text messages
                                    msgType == 0x03 || msgType == 0x04 || // Position/telemetry
                                    msgType == 0x08 || msgType == 0x09 || // Other user content
                                    (msgType >= 0x40 && msgType <= 0x7F) || // User app range
                                    length > 20); // Longer packets likely contain user data
      
      Serial.printf("[PSK] Analysis: MsgType=0x%02X, Length=%d, Routing=%s, UserMsg=%s\n", 
                    msgType, length, isRoutingPattern ? "YES" : "NO", 
                    isPotentialUserMessage ? "POSSIBLE" : "NO");
      
      // Enhanced text extraction - try multiple approaches
      if (!isRoutingPattern || isPotentialUserMessage) {
        Serial.println("[PSK] Searching for text content...");
        
        // Method 1: Look for substantial text content (standard approach)
        for (size_t startPos = 8; startPos < length - 2; startPos++) {
          String candidate = "";
          size_t consecutiveText = 0;
          
          for (size_t i = startPos; i < length && candidate.length() < 128; i++) {
            if (data[i] >= 32 && data[i] <= 126) {  // Printable ASCII
              candidate += (char)data[i];
              consecutiveText++;
            } else if (data[i] == 0) {
              break;  // Null terminator
            } else if (data[i] < 32) {
              // Allow some control chars but break on too many
              if (consecutiveText > 0 && candidate.length() < 64) {
                candidate += '.';  // Represent as dot
              } else {
                break;
              }
            } else {
              break;  // Non-ASCII
            }
          }
          
          // Improved validation for user text messages
          if (candidate.length() >= 3) {  // Lower threshold for detection
            // Additional validation - exclude obvious routing fragments
            bool isValidMessage = true;
            String lower = candidate;
            lower.toLowerCase();
            
            // Exclude common routing patterns
            if (candidate.length() < 3 || 
                (candidate.length() == 2 && candidate == "cf") ||
                candidate.startsWith("`cf") || candidate.startsWith("Tcf") ||
                candidate.startsWith("1cf") || candidate == "63f" ||
                (candidate.length() < 6 && consecutiveText < 3)) {
              isValidMessage = false;
            }
            
            if (isValidMessage && consecutiveText >= 3) {
              messageText = candidate;
              isTextMessage = true;
              Serial.printf("[PSK] 📧 FOUND TEXT MESSAGE: \"%s\" (method 1)\n", messageText.c_str());
              break;
            }
          }
        }
        
        // Method 2: Look for protobuf-style text (Meshtastic uses protobuf)
        if (!isTextMessage && length > 12) {
          Serial.println("[PSK] Trying protobuf text extraction...");
          for (size_t i = 8; i < length - 4; i++) {
            // Look for protobuf string fields (tag + length + data)
            if (data[i] >= 0x08 && data[i] <= 0x7F && i + 2 < length) {
              uint8_t fieldTag = data[i];
              uint8_t strLen = data[i + 1];
              
              if (strLen > 2 && strLen < 64 && i + 1 + strLen < length) {
                String pbText = "";
                bool validText = true;
                
                for (uint8_t j = 0; j < strLen && validText; j++) {
                  uint8_t c = data[i + 2 + j];
                  if (c >= 32 && c <= 126) {
                    pbText += (char)c;
                  } else if (c == 0) {
                    break;
                  } else {
                    validText = false;
                  }
                }
                
                if (validText && pbText.length() >= 3) {
                  messageText = pbText;
                  isTextMessage = true;
                  Serial.printf("[PSK] 📧 PROTOBUF TEXT MESSAGE: \"%s\" (tag=0x%02X)\n", 
                               messageText.c_str(), fieldTag);
                  break;
                }
              }
            }
          }
        }
      }
      
      if (!isTextMessage) {
        // Analyze as routing/control message
        Serial.print("[PSK] Control/Routing Data: ");
        for (size_t i = 8; i < length; i++) {
          if (data[i] >= 32 && data[i] <= 126) {
            Serial.printf("'%c' ", data[i]);
          } else {
            Serial.printf("0x%02X ", data[i]);
          }
        }
        Serial.println();
        
        // Enhanced message type identification
        if (length <= 16 && ((data[8] >= 0x0A && data[8] <= 0x2F) || 
                             (data[length-2] == 0x63 && data[length-1] == 0x66))) {
          Serial.println("[PSK] >>> MESH ROUTING/CONTROL MESSAGE <<<");
          Serial.printf("[PSK] Message subtype: 0x%02X (routing protocol)\n", data[8]);
        } else if (length > 20) {
          Serial.println("[PSK] >>> POSSIBLE USER DATA MESSAGE <<<");
          Serial.println("[PSK] ⚠️ No readable text found - may be binary data or different encoding");
        } else {
          Serial.println("[PSK] >>> SHORT CONTROL MESSAGE <<<");
        }
        
        // Debug: Show full packet analysis for troubleshooting
        if (!isTextMessage) {
          Serial.println("[PSK] 🔍 FULL PACKET ANALYSIS (no text found):");
          Serial.print("[PSK] Hex: ");
          for (size_t i = 0; i < length; i++) {
            Serial.printf("%02X ", data[i]);
          }
          Serial.println();
          Serial.print("[PSK] ASCII attempt: ");
          for (size_t i = 8; i < length; i++) {
            if (data[i] >= 32 && data[i] <= 126) {
              Serial.printf("'%c' ", data[i]);
            } else {
              Serial.printf("[%02X] ", data[i]);
            }
          }
          Serial.println();
        }
      } else {
        Serial.println("[PSK] >>> USER TEXT MESSAGE DETECTED <<<");
      }
    }
    
    // Determine if this is actually user plaintext or just unencrypted protocol data
    if (isTextMessage) {
      Serial.println("[PSK] 📧 USER PLAINTEXT MESSAGE detected - no encryption used");
      pskStats.successes++;
    } else {
      Serial.println("[PSK] 🔧 UNENCRYPTED PROTOCOL DATA - no user message content");
    }
    return true;
  }
  
  // Only try PSK decryption on longer packets that might be encrypted
  if (length < 20) {
    Serial.println("[PSK] Packet too short for encrypted content");
    return false;
  }
  
  // Skip Meshtastic header (first 8 bytes for node ID) and try decryption
  const uint8_t* encryptedData = data + 8;
  size_t encryptedLen = length - 8;
  
  for (uint8_t i = 0; i < NUM_DEFAULT_PSKS; i++) {
    uint8_t key[16];
    if (!decodeBase64(defaultPSKs[i], key, sizeof(key))) continue;
    
    // AES decrypt
    mbedtls_aes_context aes;
    mbedtls_aes_init(&aes);
    
    if (mbedtls_aes_setkey_dec(&aes, key, 128) != 0) {
      mbedtls_aes_free(&aes);
      continue;
    }
    
    uint8_t decrypted[PACKET_BUFFER_SIZE];
    bool validDecryption = true;
    
    // Decrypt in 16-byte blocks
    for (size_t j = 0; j < encryptedLen - 15; j += 16) {
      if (mbedtls_aes_crypt_ecb(&aes, MBEDTLS_AES_DECRYPT, 
                                encryptedData + j, decrypted + j) != 0) {
        validDecryption = false;
        break;
      }
    }
    
    mbedtls_aes_free(&aes);
    
    // Enhanced validation and message extraction from decrypted content
    if (validDecryption && decrypted[0] != 0x00) {
      pskStats.successes++;
      pskStats.hitCount[i]++;
      
      Serial.printf("[PSK] 🔓 DECRYPTION SUCCESS with default key #%d!\n", i + 1);
      Serial.println("[PSK] === DECRYPTED MESSAGE ANALYSIS ===");
      
      // Display original encrypted data
      Serial.print("[PSK] Encrypted data: ");
      for (size_t j = 0; j < min(encryptedLen, size_t(16)); j++) {
        Serial.printf("%02X ", encryptedData[j]);
      }
      if (encryptedLen > 16) Serial.print("...");
      Serial.println();
      
      // Analyze decrypted message structure
      Serial.print("[PSK] Decrypted hex: ");
      for (size_t j = 0; j < min(encryptedLen, size_t(32)); j++) {
        Serial.printf("%02X ", decrypted[j]);
      }
      if (encryptedLen > 32) Serial.print("...");
      Serial.println();
      
      // Look for text messages in decrypted content
      bool foundTextMessage = false;
      String messageText = "";
      
      // Search for readable text in decrypted payload
      for (size_t startPos = 0; startPos < encryptedLen - 3 && startPos < 20; startPos++) {
        String candidate = "";
        bool foundText = false;
        
        for (size_t j = startPos; j < min(encryptedLen, size_t(64)); j++) {
          if (decrypted[j] >= 32 && decrypted[j] <= 126) {  // Printable ASCII
            candidate += (char)decrypted[j];
            foundText = true;
          } else if (decrypted[j] == 0) {
            break;  // Null terminator
          } else if (foundText && candidate.length() > 2) {
            break;  // End of text section
          }
        }
        
        if (candidate.length() >= 3) {  // Minimum meaningful text length
          messageText = candidate;
          foundTextMessage = true;
          Serial.printf("[PSK] 📧 DECRYPTED TEXT MESSAGE: \"%s\"\n", messageText.c_str());
          break;
        }
      }
      
      if (!foundTextMessage) {
        // Display raw decrypted content with ASCII interpretation
        Serial.print("[PSK] 🔍 Decrypted content: ");
        for (size_t j = 0; j < min(encryptedLen, size_t(64)); j++) {
          if (decrypted[j] >= 32 && decrypted[j] <= 126) {
            Serial.printf("'%c' ", decrypted[j]);
          } else {
            Serial.printf("0x%02X ", decrypted[j]);
          }
        }
        Serial.println();
        
        // Try to identify message type
        if (encryptedLen < 32) {
          Serial.println("[PSK] >>> DECRYPTED CONTROL/ROUTING MESSAGE <<<");
        } else {
          Serial.println("[PSK] >>> DECRYPTED DATA MESSAGE (non-text) <<<");
        }
      } else {
        Serial.println("[PSK] >>> 🎯 USER TEXT MESSAGE SUCCESSFULLY DECRYPTED! <<<");
      }
      
      Serial.printf("[PSK] Key used: \"%s\" (Default key #%d)\n", defaultPSKs[i], i + 1);
      Serial.println("[PSK] === END DECRYPTION ANALYSIS ===");
      
      return true;
    }
  }
  
  return false;
}
#endif

// Save packet to JSON log
void logPacket(const uint8_t* data, size_t length, float rssi, float snr, const char* protocol) {
  if (!LittleFS.begin()) return;
  
  File logFile = LittleFS.open("/packets.jsonl", "a");
  if (!logFile) return;
  
  JsonDocument doc;
  doc["timestamp"] = millis();
  doc["config"] = scanConfigs[scanState.currentConfig].protocol;
  doc["frequency"] = scanConfigs[scanState.currentConfig].frequency;
  doc["protocol"] = protocol;
  doc["length"] = length;
  doc["rssi"] = rssi;
  doc["snr"] = snr;
  
  // Store packet data as hex string
  String hexData = "";
  for (size_t i = 0; i < min(length, size_t(64)); i++) {
    char hex[3];
    sprintf(hex, "%02X", data[i]);
    hexData += hex;
  }
  doc["data"] = hexData;
  
  serializeJson(doc, logFile);
  logFile.println();
  logFile.close();
}

// Print scanning statistics
void printStats() {
  Serial.println("\n=== RECONNAISSANCE SUMMARY ===");
  Serial.printf("Total packets: %d\n", scanState.totalPackets);
  Serial.printf("Active nodes: %d\n", nodeCount);
  Serial.printf("Current: %s\n", scanConfigs[scanState.currentConfig].protocol);
  
  if (nodeCount > 0) {
    Serial.println("\n--- Tracked Nodes ---");
    for (uint8_t i = 0; i < nodeCount; i++) {
      TrackedNode& node = trackedNodes[i];
      if (node.active) {
        uint32_t ageMs = millis() - node.lastSeen;
        Serial.printf("0x%08X (%s): %d pkts, %.1f dBm avg, %ds ago\n",
                      node.nodeId, node.protocol.c_str(), node.packetCount,
                      node.avgRSSI, ageMs / 1000);
      }
    }
  }
  
  #ifdef ENABLE_PSK_TESTING
  if (pskStats.attempts > 0) {
    Serial.println("\n--- PSK Testing Stats ---");
    Serial.printf("Attempts: %d, Successes: %d (%.1f%%)\n", 
                  pskStats.attempts, pskStats.successes,
                  (float)pskStats.successes / pskStats.attempts * 100.0);
    
    for (uint8_t i = 0; i < NUM_DEFAULT_PSKS; i++) {
      if (pskStats.hitCount[i] > 0) {
        Serial.printf("  Key #%d: %d hits\n", i + 1, pskStats.hitCount[i]);
      }
    }
  }
  #endif
  
  Serial.println("==============================\n");
}

void setup() {
  Serial.begin(115200);
  delay(2000);
  
  Serial.println("ESP32 LoRa Reconnaissance Tool");
  Serial.println("==============================");
  Serial.println("Hardware: ESP32-S3 + SX1262 LoRa");
  Serial.printf("Scanning %d configurations\n", NUM_CONFIGS);
  
  #ifdef ENABLE_PSK_TESTING
  Serial.printf("PSK testing: ENABLED (%d default keys)\n", NUM_DEFAULT_PSKS);
  #else
  Serial.println("PSK testing: DISABLED");
  #endif
  
  Serial.println();
  
  // Initialize storage
  if (LittleFS.begin()) {
    Serial.println("[FS] Storage ready");
  } else {
    Serial.println("[FS] Storage init failed");
  }
  
  // Initialize SPI and radio
  SPI.begin(SCK, MISO, MOSI, LORA_NSS);
  
  Serial.print("[RADIO] Initializing SX1262... ");
  int state = radio.begin();
  if (state != RADIOLIB_ERR_NONE) {
    Serial.printf("FAILED (%d)\n", state);
    while (1) delay(1000);
  }
  Serial.println("OK");
  
  // Set interrupt handler
  radio.setDio1Action(onPacketReceived);
  
  // Initialize reconnaissance system
  scanState.mode = MODE_RECONNAISSANCE;
  scanState.currentConfig = 0;
  scanState.targetConfig = 0;
  scanState.lastScanSwitch = millis();
  scanState.totalPackets = 0;
  scanState.totalDetections = 0;
  scanState.packetPending = false;
  scanState.reconStartTime = millis();
  scanState.waitingForUserInput = false;
  numReconDevices = 0;
  
  Serial.println("=== STARTING RECONNAISSANCE PHASE ===");
  Serial.println("Scanning all frequencies to detect active devices...");
  Serial.println("This will take approximately 2-3 minutes.");
  Serial.println("Press 'm' anytime to enter menu mode.");
  Serial.println();
  
  // Apply initial configuration and start receiving
  if (applyConfig(scanState.currentConfig)) {
    radio.startReceive();
    Serial.println("[RECON] Started\n");
  } else {
    Serial.println("[ERROR] Failed to apply initial config");
    while (1) delay(1000);
  }
  
  // Initialize optional modules
  initializeStressTesting();
#ifdef ENABLE_INTELLIGENCE_STORAGE
  Serial.println("📊 Intelligence storage available (press 'i' in menu)");
#endif
}

// Handle user input commands
void handleUserInput(char cmd) {
  if (cmd == 'm' || cmd == 'M') {
    scanState.mode = MODE_INTERACTIVE_MENU;
    showReconResults();
    return;
  }
  
#ifdef ENABLE_STRESS_TESTING
  if (cmd == 't' || cmd == 'T') {
    showStressTestMenu();
    return;
  }
#endif

#ifdef ENABLE_INTELLIGENCE_STORAGE
  if (cmd == 'i' || cmd == 'I') {
    showIntelligenceMenu();
    return;
  }
#endif
  
  if (cmd == 'd' || cmd == 'D') {
    showDeviceTypeSummary();
    Serial.print("\nPress any key to continue: ");
    return;
  }
  
  if (cmd == 'r' || cmd == 'R') {
    // Restart reconnaissance
    scanState.mode = MODE_RECONNAISSANCE;
    scanState.currentConfig = 0;
    scanState.lastScanSwitch = millis();
    scanState.reconStartTime = millis();
    scanState.totalDetections = 0;
    numReconDevices = 0;
    
    Serial.println("\n=== RESTARTING RECONNAISSANCE ===");
    applyConfig(scanState.currentConfig);
    radio.startReceive();
    return;
  }
  
  if (cmd == 's' || cmd == 'S') {
    showReconResults();
    return;
  }
  
  // Device selection (1-9)
  if (cmd >= '1' && cmd <= '9') {
    uint8_t deviceIndex = cmd - '1';
    if (deviceIndex < numReconDevices) {
      startTargetedCapture(deviceIndex);
    } else {
      Serial.println("Invalid device number. Try again.");
      showReconResults();
    }
    return;
  }
}

// Start targeted capture mode on specific device
void startTargetedCapture(uint8_t deviceIndex) {
  ReconDevice& target = reconDevices[deviceIndex];
  
  scanState.mode = MODE_TARGETED_CAPTURE;
  scanState.targetConfig = target.configIndex;
  scanState.currentConfig = target.configIndex;
  
  Serial.println("\n" + String('=').substring(0,50));
  Serial.println("      TARGETED CAPTURE MODE ACTIVE");
  Serial.println(String('=').substring(0,50));
  Serial.printf("Target: Device #%d\n", deviceIndex + 1);
  Serial.printf("Config: %s\n", scanConfigs[target.configIndex].protocol);
  Serial.printf("Frequency: %.3f MHz\n", scanConfigs[target.configIndex].frequency);
  Serial.printf("Best RSSI: %.1f dBm\n", target.bestRSSI);
  Serial.println("\nPress 'm' to return to menu, 'r' to restart recon");
  Serial.println("Monitoring for packets...\n");
  
  applyConfig(scanState.targetConfig);
  radio.startReceive();
}

// Handle reconnaissance mode operations
void handleReconnaissanceMode(uint32_t now) {
  // Handle frequency switching in recon mode
  if (now - scanState.lastScanSwitch >= SCAN_DWELL_TIME) {
    scanState.currentConfig = (scanState.currentConfig + 1) % NUM_CONFIGS;
    scanState.lastScanSwitch = now;
    
    // Show progress every full cycle (when back to config 0)
    if (scanState.currentConfig == 0) {
      uint32_t elapsed = (now - scanState.reconStartTime) / 1000;
      Serial.printf("[RECON] Cycle complete - %lu seconds elapsed, %d devices found\n", 
                    elapsed, numReconDevices);
    }
    
    if (applyConfig(scanState.currentConfig)) {
      radio.startReceive();
    }
  }
  
  // Handle packets in recon mode
  handlePacketReception();
  
  // Enhanced activity monitoring for recon
  handleReconActivityMonitoring(now);
}

// Handle targeted capture mode operations  
void handleTargetedCaptureMode(uint32_t now) {
  // Simplified targeting - focus on stability first
  static uint32_t lastDebug = 0;
  
  if (now - lastDebug >= 10000) {  // Every 10 seconds
    Serial.printf("[DEBUG] Targeted mode: %s, Node: 0x%08X\n", 
                  scanConfigs[scanState.targetConfig].protocol,
                  reconDevices[scanState.targetDevice].nodeId);
    lastDebug = now;
  }
  
  // Focus on primary configuration - no switching for now to avoid breaking reception
  handlePacketReception();
  
  // More frequent activity monitoring in targeted mode
  static uint32_t lastTargetActivity = 0;
  if (now - lastTargetActivity >= 500) {  // Check every 500ms
    float currentRSSI = radio.getRSSI(false);
    if (currentRSSI > -110.0) {
      Serial.printf("[TARGET] RSSI: %.1f dBm\n", currentRSSI);
    }
    lastTargetActivity = now;
  }
}

// Unified packet reception handler
void handlePacketReception() {
  if (!packetReceived) return;
  
  packetReceived = false;
  
  // Debug: Log that packet reception is being called
  Serial.println("[DEBUG] Packet reception handler called");
  
  String packet;
  int state = radio.readData(packet);
  
  if (state == RADIOLIB_ERR_NONE && packet.length() > 0) {
    scanState.totalPackets++;
    
    float rssi = radio.getRSSI();
    float snr = radio.getSNR();
    
    const uint8_t* data = (const uint8_t*)packet.c_str();
    size_t length = packet.length();
    
    const char* protocol = identifyProtocol(data, length);
    uint32_t nodeId = extractNodeId(data, length, protocol);
    
    // Enhanced packet analysis for Meshtastic
    if (strcmp(protocol, "Meshtastic") == 0) {
      Serial.printf("[PACKET] Meshtastic structure analysis:\n");
      Serial.printf("  - Length: %d bytes\n", length);
      Serial.printf("  - Node ID: 0x%08X\n", nodeId);
      if (length > 8) {
        Serial.printf("  - Payload type: 0x%02X\n", data[8]);
        if (length > 9) {
          Serial.printf("  - Flags/Seq: 0x%02X\n", data[9]);
        }
      }
    }
    
    if (scanState.mode == MODE_RECONNAISSANCE) {
      Serial.printf("[RECON] Packet #%d: %s, %d bytes, %.1f dBm, %.1f dB SNR\n",
                    scanState.totalPackets, protocol, length, rssi, snr);
      
      // Track for reconnaissance
        trackReconDevice(scanState.currentConfig, rssi, true, nodeId, protocol, data, length);
    
    } else if (scanState.mode == MODE_TARGETED_CAPTURE) {
      Serial.printf("[CAPTURE] Packet #%d: %s, %d bytes, %.1f dBm, %.1f dB SNR\n",
                    scanState.totalPackets, protocol, length, rssi, snr);
      
      #ifdef ENABLE_PSK_TESTING
      // PSK testing only in targeted mode
      if (strcmp(protocol, "Meshtastic") == 0 && length >= 8) {
        Serial.printf("[PSK] Attempting decryption on %d-byte packet\n", length);
        testDefaultPSKs(data, length);
      }
      #endif
    }
    
    // Always track nodes and log packets
    if (nodeId != 0) {
      trackNode(nodeId, protocol, rssi);
    }
    
    logPacket(data, length, rssi, snr, protocol);
    
    // Show hex data
    Serial.print("     Data: ");
    for (size_t i = 0; i < min(length, size_t(16)); i++) {
      Serial.printf("%02X ", data[i]);
    }
    if (length > 16) Serial.print("...");
    Serial.println();
    
  } else if (state != RADIOLIB_ERR_NONE) {
    if (scanState.mode == MODE_TARGETED_CAPTURE) {
      Serial.printf("[TARGET] RX Error: %d\n", state);
    }
  }
  
  // Restart receiving
  radio.startReceive();
}

// Handle activity monitoring during reconnaissance
void handleReconActivityMonitoring(uint32_t now) {
  static uint32_t lastActivityCheck = 0;
  static float lastRSSI = -127.0;
  
  if (now - lastActivityCheck >= 1000) {  // Check every 1 second (more frequent)
    float currentRSSI = radio.getRSSI(false);
    
    // More sensitive activity detection
    bool activityDetected = (currentRSSI > -110.0);  // Lower threshold
    bool spikeDetected = (currentRSSI - lastRSSI) > 15.0;  // Lower spike threshold
    bool strongSignal = (currentRSSI > -70.0);  // Detect strong nearby signals
    
    if (activityDetected || spikeDetected || strongSignal) {
      scanState.totalDetections++;
      
      if (strongSignal) {
        Serial.printf("[RECON] Strong signal detected: %.1f dBm on %s - LIKELY DEVICE NEARBY\n", 
                      currentRSSI, scanConfigs[scanState.currentConfig].protocol);
      } else if (spikeDetected) {
        Serial.printf("[RECON] Activity spike: %.1f dBm (+%.1f) on %s\n", 
                      currentRSSI, currentRSSI - lastRSSI, 
                      scanConfigs[scanState.currentConfig].protocol);
      } else {
        Serial.printf("[RECON] Activity: %.1f dBm on %s\n", 
                      currentRSSI, scanConfigs[scanState.currentConfig].protocol);
      }
      
      // Enhanced device tracking - avoid creating duplicate pseudo IDs
      uint32_t pseudoNodeId = 0;
      
      // Aggressive deduplication - check for similar devices across ALL configs
      bool existingDevice = false;
      for (uint8_t i = 0; i < numReconDevices; i++) {
        // Group devices by signal strength ranges (same physical device)
        float rssiDiff = abs(reconDevices[i].bestRSSI - currentRSSI);
        
        if (rssiDiff < 10.0) {  // Very similar signal strength = same device
          existingDevice = true;
          pseudoNodeId = reconDevices[i].nodeId;
          
          // Update the existing device instead of creating new one
          Serial.printf("[RECON] Updating existing device 0x%08X (RSSI diff: %.1f)\\n\", 
                        pseudoNodeId, rssiDiff);
          break;
        }
      }
      
      if (!existingDevice && currentRSSI > -80) {
        // Create stable pseudo node ID based on config and RSSI range
        uint8_t rssiRange = (uint8_t)(-currentRSSI / 10);  // Group by 10dBm ranges
        pseudoNodeId = (0xAA000000 + (scanState.currentConfig << 16) + (rssiRange << 8));
        Serial.printf("[RECON] New signal source: 0x%08X\n", pseudoNodeId);
      }
      
      const char* detectedProtocol = scanConfigs[scanState.currentConfig].protocol;
      trackReconDevice(scanState.currentConfig, currentRSSI, false, pseudoNodeId, detectedProtocol, nullptr, 0);
    }
    
    // Track signal persistence for better device identification
    if (currentRSSI > -90.0) {
      static uint8_t persistentSignalCount = 0;
      static float persistentRSSI = 0;
      
      persistentSignalCount++;
      persistentRSSI = (persistentRSSI + currentRSSI) / 2.0;
      
      if (persistentSignalCount >= 3) {  // Signal seen 3+ times
        Serial.printf("[RECON] Persistent device detected: avg %.1f dBm over %d checks\n", 
                      persistentRSSI, persistentSignalCount);
        persistentSignalCount = 0;  // Reset counter
      }
    }
    
    lastRSSI = currentRSSI;
    lastActivityCheck = now;
  }
}

void loop() {
  uint32_t now = millis();
  
  // Handle serial input for mode switching and commands
  if (Serial.available()) {
    char cmd = Serial.read();
    handleUserInput(cmd);
    return;
  }
  
  // Mode-specific operations
  switch (scanState.mode) {
    case MODE_RECONNAISSANCE:
      handleReconnaissanceMode(now);
      break;
      
    case MODE_TARGETED_CAPTURE:
      handleTargetedCaptureMode(now);
      break;
      
    case MODE_INTERACTIVE_MENU:
      // Just wait for user input
      delay(100);
      return;
  }
  
  delay(10);
}

#ifdef ENABLE_STRESS_TESTING
// Hardware stress testing menu
void showStressTestMenu() {
  Serial.println("\n🧪 HARDWARE STRESS TESTING");
  Serial.println("============================");
  Serial.println("⚠️ Safety limits enabled - testing within safe parameters");
  Serial.println();
  
  // Initialize stress tester if not already done
  if (!stressTester) {
    Serial.print("🔧 Initializing stress testing framework... ");
    stressTester = new HardwareStressTester(&radio);
    if (stressTester->initializeStressTesting()) {
      Serial.println("✅ SUCCESS");
    } else {
      Serial.println("❌ FAILED");
      Serial.println("Stress testing not available - returning to main menu");
      scanState.mode = MODE_INTERACTIVE_MENU;
      return;
    }
  }
  
  Serial.println("TEST OPTIONS:");
  Serial.println("1 : T-Deck targeted assessment");
  Serial.println("2 : Frequency sweep test");
  Serial.println("3 : Power ramp validation");
  Serial.println("4 : Parameter boundary test");
  Serial.println("5 : Rapid config stress test");
  Serial.println("6 : Memory integrity test");
  Serial.println("7 : Thermal monitoring test");
  Serial.println("8 : Full validation suite");
  Serial.println("9 : Show last test report");
  Serial.println("r : Return to main menu");
  Serial.print("\nSelect test (1-9) or command: ");
  
  // Wait for user input
  while (!Serial.available()) {
    delay(10);
  }
  
  char cmd = Serial.read();
  Serial.println(cmd);
  
  runHardwareStressTest(cmd);
}

// Execute selected stress test
void runHardwareStressTest(char testChoice) {
  bool testResult = false;
  
  switch (testChoice) {
    case '1':
      Serial.println("\n🎯 Running T-Deck Targeted Assessment...");
      testResult = stressTester->runStressTest(TDECK_TARGETED_TEST);
      break;
      
    case '2':
      Serial.println("\n📡 Running Frequency Sweep Test...");
      testResult = stressTester->runStressTest(FREQUENCY_SWEEP_TEST);
      break;
      
    case '3':
      Serial.println("\n⚡ Running Power Ramp Test...");
      testResult = stressTester->runStressTest(POWER_RAMP_TEST);
      break;
      
    case '4':
      Serial.println("\n🔧 Running Parameter Boundary Test...");
      testResult = stressTester->runStressTest(PARAMETER_BOUNDARY_TEST);
      break;
      
    case '5':
      Serial.println("\n⚡ Running Rapid Config Stress Test...");
      testResult = stressTester->runStressTest(RAPID_CONFIG_CHANGE_TEST);
      break;
      
    case '6':
      Serial.println("\n💾 Running Memory Integrity Test...");
      testResult = stressTester->runStressTest(MEMORY_STRESS_TEST);
      break;
      
    case '7':
      Serial.println("\n🌡️ Running Thermal Monitoring Test...");
      testResult = stressTester->runStressTest(THERMAL_STRESS_TEST);
      break;
      
    case '8':
      {
        Serial.println("\n🧪 Running Full Validation Suite...");
        Serial.println("This will run all tests sequentially...");
        
      // Run all tests with proper cooldown management
      int passedTests = 0;
      
      // Helper function for cooldown with countdown
      auto waitForCooldown = [](int seconds) {
        Serial.printf("⏱️ Hardware cooldown: ");
        for (int i = seconds; i > 0; i--) {
          Serial.printf("%d ", i);
          Serial.flush();
          delay(1000);
        }
        Serial.println("✅ Ready");
      };
      
      // Initial cooldown to ensure hardware is ready
      Serial.println("🔧 Preparing hardware for validation suite...");
      waitForCooldown(5);
      
      Serial.println("\n1/7: T-Deck Assessment");
      if (stressTester->runStressTest(TDECK_TARGETED_TEST)) passedTests++;
      waitForCooldown(30);
      
      Serial.println("2/7: Frequency Sweep");
      if (stressTester->runStressTest(FREQUENCY_SWEEP_TEST)) passedTests++;
      waitForCooldown(30);
      
      Serial.println("3/7: Power Validation");
      if (stressTester->runStressTest(POWER_RAMP_TEST)) passedTests++;
      waitForCooldown(30);
      
      Serial.println("4/7: Parameter Boundaries");
      if (stressTester->runStressTest(PARAMETER_BOUNDARY_TEST)) passedTests++;
      waitForCooldown(30);
      
      Serial.println("5/7: Rapid Config Stress");
      if (stressTester->runStressTest(RAPID_CONFIG_CHANGE_TEST)) passedTests++;
      waitForCooldown(30);
      
      Serial.println("6/7: Memory Integrity");
      if (stressTester->runStressTest(MEMORY_STRESS_TEST)) passedTests++;
      waitForCooldown(30);
      
      Serial.println("7/7: Thermal Monitoring");
      if (stressTester->runStressTest(THERMAL_STRESS_TEST)) passedTests++;      Serial.printf("\n🎯 VALIDATION COMPLETE: %d/7 tests passed (%.1f%%)\n", 
                    passedTests, (passedTests / 7.0) * 100.0);
      
      if (passedTests >= 6) {
        Serial.println("🏆 VERDICT: Hardware excellent for security research");
      } else if (passedTests >= 4) {
        Serial.println("✅ VERDICT: Hardware good with minor limitations");
      } else {
        Serial.println("⚠️ VERDICT: Hardware stability concerns detected");
      }
      
      testResult = (passedTests >= 4);
      }
      break;
      
    case '9':
      Serial.println("\n📊 Last Test Report:");
      stressTester->printStressTestReport();
      Serial.println("\nPress any key to continue...");
      while (!Serial.available()) delay(10);
      Serial.read();
      showStressTestMenu();
      return;
      
    case 'r':
    case 'R':
      scanState.mode = MODE_INTERACTIVE_MENU;
      showReconResults();
      return;
      
    default:
      Serial.println("❌ Invalid selection");
      delay(1000);
      showStressTestMenu();
      return;
  }
  
  // Show test result
  Serial.printf("\n📊 Test Result: %s\n", testResult ? "✅ PASS" : "❌ FAIL");
  
  // Show safety status
  SafetyMonitor status = stressTester->getSafetyStatus();
  Serial.printf("🛡️ Safety Status: %s\n", status.thermalShutdown ? "⚠️ SHUTDOWN" : "✅ OK");
  Serial.printf("🌡️ Temperature: %.1f°C\n", status.currentTemperature);
  
  Serial.println("\nPress any key to return to stress test menu...");
  while (!Serial.available()) delay(10);
  Serial.read();
  
  showStressTestMenu();
}

// Initialize stress testing in setup()
void initializeStressTesting() {
  #ifdef ENABLE_STRESS_TESTING
  // Stress tester will be initialized on first use for efficiency
  Serial.println("⚠️ Hardware stress testing available (press 't' in menu)");
  #endif
}
#endif

#ifdef ENABLE_INTELLIGENCE_STORAGE
// Intelligence analysis menu
void showIntelligenceMenu() {
  Serial.println("\n📊 INTELLIGENCE ANALYSIS");
  Serial.println("=========================");
  
  // Initialize intelligence storage if not already done
  if (!intelligenceStorageInitialized) {
    Serial.print("🔧 Initializing intelligence storage... ");
    if (intelligenceStorage.initialize()) {
      intelligenceStorageInitialized = true;
      Serial.println("✅ SUCCESS");
    } else {
      Serial.println("❌ FAILED");
      Serial.println("Intelligence storage not available - returning to main menu");
      scanState.mode = MODE_INTERACTIVE_MENU;
      return;
    }
  }
  
  // Show current session status
  ReconSession currentSession = intelligenceStorage.getCurrentSession();
  Serial.printf("📋 Current Session: %s\n", currentSession.sessionId.c_str());
  Serial.printf("📅 Started: %lu\n", currentSession.startTime);
  Serial.printf("📦 Decrypted Packets: %d\n", currentSession.decryptedPackets);
  Serial.printf("📡 Total Packets: %d\n", currentSession.totalPackets);
  
  Serial.println("\nINTELLIGENCE OPTIONS:");
  Serial.println("1 : Start new intelligence session");
  Serial.println("2 : Export current session (JSON)");
  Serial.println("3 : Export session report");
  Serial.println("4 : Search intelligence by node ID");
  Serial.println("5 : Show storage statistics");
  Serial.println("6 : Storage health check");
  Serial.println("7 : List all sessions");
  Serial.println("8 : Cleanup old data");
  Serial.println("r : Return to main menu");
  Serial.print("\nSelect option (1-8) or command: ");
  
  // Wait for user input
  while (!Serial.available()) {
    delay(10);
  }
  
  char cmd = Serial.read();
  Serial.println(cmd);
  
  runIntelligenceCommand(cmd);
}

// Execute selected intelligence command
void runIntelligenceCommand(char cmd) {
  switch (cmd) {
    case '1':
      {
        Serial.println("\n📋 Starting New Intelligence Session...");
        Serial.print("Enter campaign name (or press Enter for auto): ");
        
        // Simple input handling
        String campaignName = "";
        unsigned long inputStart = millis();
        while (millis() - inputStart < 10000) { // 10 second timeout
          if (Serial.available()) {
            campaignName = Serial.readStringUntil('\n');
            campaignName.trim();
            break;
          }
          delay(10);
        }
        
        if (campaignName.length() == 0) {
          campaignName = "AutoRecon_" + String(millis());
        }
        
        if (intelligenceStorage.startNewSession(campaignName, "LoRa reconnaissance session")) {
          Serial.printf("✅ New session started: %s\n", campaignName.c_str());
        } else {
          Serial.println("❌ Failed to start new session");
        }
      }
      break;
      
    case '2':
      {
        Serial.println("\n📤 Exporting Current Session...");
        ReconSession session = intelligenceStorage.getCurrentSession();
        String exportPath = "/exports/" + session.sessionId + ".json";
        
        Serial.printf("💾 Export path: %s\n", exportPath.c_str());
        Serial.println("⚠️ Export functionality not yet implemented");
        Serial.println("Data is stored internally for current session");
      }
      break;
      
    case '3':
      {
        Serial.println("\n📋 Intelligence Report:");
        ReconSession session = intelligenceStorage.getCurrentSession();
        Serial.printf("Session: %s\n", session.sessionId.c_str());
        Serial.printf("Campaign: %s\n", session.campaignName.c_str());
        Serial.printf("Packets: %d\n", session.totalPackets);
        Serial.printf("Decrypted: %d\n", session.decryptedPackets);
        Serial.printf("Unique Nodes: %d\n", session.uniqueNodes);
      }
      break;
      
    case '4':
      {
        Serial.println("\n🔍 Search Intelligence by Node ID...");
        Serial.print("Enter node ID (hex, e.g., 0x401ACD4E): ");
        
        String nodeId = "";
        unsigned long inputStart = millis();
        while (millis() - inputStart < 15000) { // 15 second timeout
          if (Serial.available()) {
            nodeId = Serial.readStringUntil('\n');
            nodeId.trim();
            break;
          }
          delay(10);
        }
        
        if (nodeId.length() > 0) {
          Serial.printf("🔍 Searching for node: %s\n", nodeId.c_str());
          Serial.println("⚠️ Search functionality not yet implemented");
          Serial.println("Use session export for complete data analysis");
        } else {
          Serial.println("❌ No node ID entered");
        }
      }
      break;
      
    case '5':
      {
        Serial.println("\n📊 Storage Statistics:");
        StorageStats stats = intelligenceStorage.getStorageStats();
        Serial.printf("💾 Total Space: %lu KB\n", stats.totalSize / 1024);
        Serial.printf("🆓 Available Space: %lu KB\n", stats.availableSpace / 1024);
        Serial.printf("📦 Sessions: %d\n", stats.totalSessions);
        Serial.printf("🧠 Intelligence Records: %d\n", stats.totalIntelligenceRecords);
        Serial.printf("� Storage Rotations: %d\n", stats.storageRotations);
        Serial.printf("📈 Usage: %.1f%%\n", ((float)(stats.totalSize - stats.availableSpace) / stats.totalSize) * 100.0);
      }
      break;
      
    case '6':
      {
        Serial.println("\n🔧 Storage Health Check...");
        bool isHealthy = intelligenceStorage.performMaintenance();
        Serial.printf("🏥 Storage Health: %s\n", isHealthy ? "✅ HEALTHY" : "⚠️ ISSUES DETECTED");
        
        if (!isHealthy) {
          Serial.println("💡 Consider running data cleanup (option 8)");
        }
      }
      break;
      
    case '7':
      {
        Serial.println("\n📋 Session Information:");
        intelligenceStorage.printSessionSummary();
        Serial.println("\n📊 Storage Status:");
        intelligenceStorage.printStorageStatus();
      }
      break;
      
    case '8':
      {
        Serial.println("\n🧹 Storage Cleanup...");
        Serial.println("⚠️ This will remove old data to free space");
        Serial.print("Continue? (y/N): ");
        
        while (!Serial.available()) delay(10);
        char confirm = Serial.read();
        Serial.println(confirm);
        
        if (confirm == 'y' || confirm == 'Y') {
          if (intelligenceStorage.deleteOldSessions(5)) {
            Serial.println("✅ Storage cleanup completed (kept 5 recent sessions)");
          } else {
            Serial.println("❌ Cleanup failed");
          }
        } else {
          Serial.println("Cleanup cancelled");
        }
      }
      break;
      
    case 'r':
    case 'R':
      scanState.mode = MODE_INTERACTIVE_MENU;
      showReconResults();
      return;
      
    default:
      Serial.println("❌ Invalid selection");
      delay(1000);
      showIntelligenceMenu();
      return;
  }
  
  Serial.println("\nPress any key to return to intelligence menu...");
  while (!Serial.available()) delay(10);
  Serial.read();
  
  showIntelligenceMenu();
}

#endif