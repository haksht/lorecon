  {902.125, 250.0, 11, 0x2b, "Meshtastic_LF_902"},
  {903.875, 250.0, 10, 0x2b, "Meshtastic_MF"},
  {904.375, 250.0,  9, 0x2b, "Meshtastic_SF"},
  
  // Focus on 902.125 MHz variations (where T-Deck reports it's configured)
  {902.125, 250.0, 10, 0x2b, "Meshtastic_902_SF10"},    // Message SF10
  {902.125, 250.0,  9, 0x2b, "Meshtastic_902_SF9"},     // Message SF9 
  {902.125, 250.0,  8, 0x2b, "Meshtastic_902_SF8"},     // Message SF8
  {902.125, 250.0, 11, 0x12, "Meshtastic_902_SW12"},    // Message sync 0x12
  {902.125, 250.0, 10, 0x12, "Meshtastic_902_SF10_SW12"}, // SF10 + sync 0x12
  {902.125, 250.0,  9, 0x12, "Meshtastic_902_SF9_SW12"},  // SF9 + sync 0x12
  
  // TTN/LoRaWAN US channels
