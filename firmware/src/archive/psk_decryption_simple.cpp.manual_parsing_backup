/*
 * CRITICAL UNDERSTANDING OF MESHTASTIC PACKET STRUCTURE
 * ======================================================
 * Based on official Meshtastic protobuf source (github.com/meshtastic/protobufs):
 * 
 * The LoRa packet structure is:
 * 1. UNENCRYPTED HEADER (16 bytes):
 *    - Bytes 0-3: Destination address (0xFFFFFFFF for broadcast)
 *    - Bytes 4-7: Sender NodeID
 *    - Byte 8: Packet type/flags
 *    - Bytes 9-12: PacketID (used in nonce for AES-CTR)
 *    - Bytes 13-15: Other routing metadata
 * 
 * 2. ENCRYPTED PAYLOAD:
 *    - This is the ENTIRE serialized "Data" protobuf message
 *    - NOT a MeshPacket! MeshPacket fields (from/to/id) are in the header
 *    
 * Data message protobuf structure:
 *    message Data {
 *      PortNum portnum = 1;    // Tag: 0x08, Value: 1=TEXT, 3=POSITION, etc.
 *      bytes payload = 2;      // Tag: 0x12, Length-delimited
 *      bool want_response = 3; // Tag: 0x18
 *      fixed32 dest = 4;       // Tag: 0x25
 *      fixed32 source = 5;     // Tag: 0x2D
 *      ...
 *    }
 * 
 * For TEXT_MESSAGE_APP (portnum=1), the payload contains:
 *    0x0A <text_length_varint> <UTF-8 text bytes>
 * 
 * This means when we decrypt, we should immediately see:
 *    0x08 0x01 0x12 <payload_len> 0x0A <text_len> <text>
 */

// Known Meshtastic default PSKs (some networks still use these)
const char* defaultPSKs[] = {
  "AQ==",                      // #1: LongFast default - USER'S DEVICES USE THIS!
  "1PG7OiApB1nwvP+rz05pAQ==",  // #2: Common default (was #1)
  "d1iq21lNSh7BP6MOkP6cQA==",  // #3: Channel 1
  "2f8aH6iT8K9jQ1P3mD4nBw==",  // #4: Channel 2
  "7h3kL9mR5wX2pY8qE6tZcA==",  // #5: Channel 3
};

const uint8_t NUM_DEFAULT_PSKS = sizeof(defaultPSKs) / sizeof(char*);

// PSK stats instance
PSKStats pskStats;

void initializePSKStats() {
    pskStats = PSKStats();  // Use constructor instead of memset
}

// Base64 decode helper
bool PSKDecryption::decodeBase64(const char* input, uint8_t* output, size_t maxLen) {
  size_t outLen;
  int result = mbedtls_base64_decode(output, maxLen, &outLen, 
                                    (const unsigned char*)input, strlen(input));
  return (result == 0 && outLen > 0);
}

// Attempt packet decryption with known PSKs
bool PSKDecryption::testDefaultPSKs(const uint8_t* data, size_t length) {
  pskStats.attempts++;
  
  // Declare variables at function scope to avoid scope issues
  bool isTextMessage = false;
  bool isRoutingPattern = false;
  String messageText = "";
  
