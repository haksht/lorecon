        Serial.println();
        Serial.println("[PSK] Possible explanations:");
        Serial.println("[PSK]   1. Meshtastic v2.6.x uses different protobuf structure");
        Serial.println("[PSK]   2. This is a non-Data packet (ACK, routing, admin)");
        Serial.println("[PSK]   3. Implicit field encoding (field tags omitted)");
        Serial.println("[PSK]   4. Compressed/custom format for bandwidth savings");
        Serial.println("[PSK] ═══════════════════════════════════");
        Serial.println();
      }
      
      // *** DEEP ANALYSIS: Multiple protobuf field formats and XOR patterns ***
      // Varint decoder helper
      auto decodeVarint = [&](size_t pos, uint32_t& value, size_t& bytesRead) -> bool {
        value = 0; bytesRead = 0; uint32_t shift = 0;
        while (pos + bytesRead < encryptedLen && bytesRead < 5) {
          uint8_t byte = decrypted[pos + bytesRead];
          value |= ((uint32_t)(byte & 0x7F)) << shift;
          bytesRead++;
          if ((byte & 0x80) == 0) return true;
          shift += 7;
        }
        return false;
      };
      
      // Search for Field 4 (0x22) or Field 3 (0x1A) anywhere in packet
      Serial.println("[PSK] 🔬 DEEP ANALYSIS: Searching for nested message fields...");
      for (size_t i = 0; i < encryptedLen; i++) {
        if (decrypted[i] == 0x1A || decrypted[i] == 0x22) {
          Serial.printf("[PSK]   Found 0x%02X (Field %d) at offset %d\n", 
                       decrypted[i], decrypted[i] >> 3, i);
        }
      }
      
      // CRITICAL INSIGHT from Meshtastic protobuf source:
      // The encrypted payload IS the Data message directly, NOT a MeshPacket!
      // MeshPacket fields (from, to, id) are in the unencrypted LoRa header.
      // So we should parse this as: Data { portnum=1, payload=2, ... }
      Serial.println("[PSK] 🎯 KEY INSIGHT: Decrypted bytes = Data protobuf (not MeshPacket!)");
      Serial.println("[PSK]    MeshPacket.from/to/id are in unencrypted header");
      Serial.println("[PSK]    We decrypt only the Data message: { portnum, payload, ... }");
      
      // Parse Data message starting from offset 0
      // Expected structure:
      //   Field 1 (portnum): tag 0x08, varint value
      //   Field 2 (payload): tag 0x12, length + bytes
      //   ...other fields...
      
      if (!foundTextMessage && encryptedLen > 2) {
        Serial.println("[PSK] 🔍 Parsing Data message from offset 0...");
        
        // IMPORTANT: Check what the first byte actually is
        uint8_t firstByte = decrypted[0];
        uint8_t firstFieldNum = firstByte >> 3;
        uint8_t firstWireType = firstByte & 0x07;
        
        Serial.printf("[PSK]    First byte: 0x%02X = Field %u, Wire %u\n", 
                     firstByte, firstFieldNum, firstWireType);
        
        // Check if first byte is portnum field tag (0x08 = field 1, wire 0)
        if (decrypted[0] == 0x08) {
          uint8_t portnum = decrypted[1];
          Serial.printf("[PSK] ✓ Field 1 (portnum) = %d ", portnum);
          switch(portnum) {
            case 0x01: Serial.println("(TEXT_MESSAGE_APP) ✉️"); break;
            case 0x03: Serial.println("(POSITION_APP) 📍"); break;
            case 0x04: Serial.println("(NODEINFO_APP) ℹ️"); break;
            case 0x07: Serial.println("(ROUTING_APP) 🔀"); break;
            default: Serial.printf("(%d)\n", portnum); break;
          }
          
          // Next should be payload field (0x12 = field 2, wire 2=length-delimited)
          if (encryptedLen > 3 && decrypted[2] == 0x12) {
            uint32_t payloadLen = 0;
            size_t varintBytes = 0;
            
            if (decodeVarint(3, payloadLen, varintBytes)) {
              size_t payloadStart = 3 + varintBytes;
              Serial.printf("[PSK] ✓ Field 2 (payload) length=%d, starts at offset %d\n", 
                           payloadLen, payloadStart);
              
              // For TEXT_MESSAGE_APP (portnum==1), payload contains:
              // 0x0A <text_length_varint> <text_bytes>
              if (portnum == 1 && payloadStart < encryptedLen && payloadLen > 0) {
                if (decrypted[payloadStart] == 0x0A) {
                  uint32_t textLen = 0;
                  size_t textVarintBytes = 0;
                  
                  if (decodeVarint(payloadStart + 1, textLen, textVarintBytes)) {
                    size_t textStart = payloadStart + 1 + textVarintBytes;
                    Serial.printf("[PSK] ✓ Text field (0x0A) length=%d, starts at offset %d\n",
                                 textLen, textStart);
                    
                    if (textLen > 0 && textLen <= 250 && (textStart + textLen) <= encryptedLen) {
                      String text = "";
                      bool validText = true;
                      
                      for (uint32_t i = 0; i < textLen; i++) {
                        uint8_t c = decrypted[textStart + i];
                        if (c >= 32 && c <= 126) {
                          text += (char)c;
                        } else if (c == 0x0A || c == 0x0D) {
                          text += '\n';
                        } else if (c == 0) {
                          break;
                        } else {
                          validText = false;
                          break;
                        }
                      }
                      
                      if (validText && text.length() >= 1) {
                        messageText = text;
                        foundTextMessage = true;
                        Serial.printf("[PSK] 🎉 SUCCESS! EXTRACTED TEXT: \"%s\"\n", messageText.c_str());
                      }
                    }
                  }
                } else {
                  // Maybe payload is raw text without 0x0A wrapper?
                  Serial.println("[PSK] ⚠️  Payload doesn't start with 0x0A, trying direct text...");
                  String directText = "";
                  size_t payloadEnd = min((size_t)(payloadStart + payloadLen), encryptedLen);
                  
                  for (size_t i = payloadStart; i < payloadEnd; i++) {
                    uint8_t c = decrypted[i];
                    if (c >= 32 && c <= 126) {
                      directText += (char)c;
                    } else if (c == 0) {
                      break;
                    }
                  }
                  
                  if (directText.length() >= 2) {
                    messageText = directText;
                    foundTextMessage = true;
                    Serial.printf("[PSK] ✅ EXTRACTED TEXT (direct): \"%s\"\n", messageText.c_str());
                  }
                }
              }
            }
          }
        } else {
          Serial.printf("[PSK] ⚠️  Expected portnum field (0x08), got 0x%02X\n", decrypted[0]);
          Serial.println("[PSK] 📍 PACKET TYPE IDENTIFICATION:");
          
          if (decrypted[0] == 0x12) {
            Serial.println("[PSK]    ✓ First byte 0x12 = Field 2 (payload) with IMPLICIT portnum");
            Serial.println("[PSK]    → This is likely a POSITION packet (portnum=3)");
            Serial.println("[PSK]    → Position packets contain GPS coords, NOT text messages");
          } else {
            Serial.println("[PSK]    • If 0x08 at start: Has explicit portnum (check next byte)");
            Serial.println("[PSK]    • If 0x12 at start: POSITION packet (implicit portnum=3)");
            Serial.println("[PSK]    • Otherwise: Routing/ACK/Admin packet (NOT user data)");
          }
          
          Serial.println("[PSK] 💡 TO CAPTURE TEXT MESSAGES:");
          Serial.println("[PSK]    → Send a text message from Meshtastic app");
          Serial.println("[PSK]    → Look for packets starting with 0x08 0x01");
          
          // Try to extract ANY readable text from the decrypted data
          Serial.println("[PSK] 🔍 Searching for any readable text in decrypted payload...");
          String anyText = "";
          for (size_t i = 0; i < encryptedLen; i++) {
            if (decrypted[i] >= 32 && decrypted[i] <= 126) {
              anyText += (char)decrypted[i];
              if (anyText.length() >= 3) {
                // Found 3+ printable chars in a row
                Serial.printf("[PSK]    Found text at offset %zu: \"", i - anyText.length() + 1);
                Serial.print(anyText);
                // Keep reading to end of text
                for (size_t j = i + 1; j < encryptedLen && decrypted[j] >= 32 && decrypted[j] <= 126; j++) {
                  anyText += (char)decrypted[j];
                  Serial.write(decrypted[j]);
                  i = j;
                }
                Serial.println("\"");
                if (anyText.length() >= 3) {
                  messageText = anyText;
                  foundTextMessage = true;
                  Serial.printf("[PSK] 🎉 FOUND TEXT (non-standard format): \"%s\"\n", messageText.c_str());
                  break;
                }
                anyText = "";
              }
            } else {
              anyText = "";  // Reset on non-printable char
            }
          }
        }
      }
      
      // Legacy parsing attempt: Look for 0x22 (Field 4, Wire 2 = "decoded" field in MeshPacket)
      if (!foundTextMessage && encryptedLen > 2 && decrypted[0] == 0x22) {
        Serial.println("[PSK] 🔍 Found Field 4 (0x22 - decoded) at start!");
        uint32_t nestedLen = 0;
        size_t varintBytes = 0;
        
        if (decodeVarint(1, nestedLen, varintBytes)) {
          size_t nestedStart = 1 + varintBytes;
          Serial.printf("[PSK] Decoded field length=%d (varint=%d bytes), starts at offset %d\n", 
                       nestedLen, varintBytes, nestedStart);
          
          if (nestedStart < encryptedLen && nestedLen > 0) {
            size_t searchEnd = min((size_t)(nestedStart + nestedLen), encryptedLen);
            
            // Look for 0x08 (portnum) inside
            for (size_t pos = nestedStart; pos < searchEnd - 2; pos++) {
              if (decrypted[pos] == 0x08) {
                uint8_t portnum = decrypted[pos + 1];
                Serial.printf("[PSK] Found portnum=0x%02X (%d) at offset %d\n", portnum, portnum, pos);
                
                // Look for 0x12 (payload) after portnum
                if (pos + 2 < searchEnd && decrypted[pos + 2] == 0x12) {
                  uint32_t payloadLen = 0;
                  size_t payloadVarintBytes = 0;
                  
                  if (decodeVarint(pos + 3, payloadLen, payloadVarintBytes)) {
                    size_t payloadStart = pos + 3 + payloadVarintBytes;
                    Serial.printf("[PSK] Found payload, len=%d\n", payloadLen);
                    
                    // Direct text extraction - maybe no 0x0A tag?
                    if (payloadStart < searchEnd && payloadLen > 0 && payloadLen <= 200) {
                      size_t payloadEnd = min((size_t)(payloadStart + payloadLen), searchEnd);
                      String directText = "";
                      
                      for (size_t i = payloadStart; i < payloadEnd; i++) {
                        uint8_t c = decrypted[i];
                        if (c >= 32 && c <= 126) {
                          directText += (char)c;
                        } else if (c == 0) {
                          break;
                        }
                      }
                      
                      if (directText.length() >= 2) {
                        messageText = directText;
                        foundTextMessage = true;
                        Serial.printf("[PSK] ✅ EXTRACTED TEXT (direct payload): \"%s\"\n", messageText.c_str());
                        break;
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
      
      // Look for 0x1A (Field 3, Wire 2 = older format)
      if (!foundTextMessage && encryptedLen > 2 && decrypted[0] == 0x1A) {
        Serial.println("[PSK] 🔍 Found Field 3 (0x1A) nested message at start!");
        uint32_t nestedLen = 0;
        size_t varintBytes = 0;
        
        if (decodeVarint(1, nestedLen, varintBytes)) {
          size_t nestedStart = 1 + varintBytes;
          Serial.printf("[PSK] Nested message length=%d (varint=%d bytes), starts at offset %d\n", 
                       nestedLen, varintBytes, nestedStart);
          
          // Now parse inside the nested message for 0x08 (portnum) and 0x12 (payload)
          if (nestedStart < encryptedLen && nestedLen > 0) {
            size_t searchEnd = min((size_t)(nestedStart + nestedLen), encryptedLen);
            
            // Look for 0x08 (portnum field) inside nested message
            for (size_t pos = nestedStart; pos < searchEnd - 2; pos++) {
              if (decrypted[pos] == 0x08) {
                uint8_t portnum = decrypted[pos + 1];
                Serial.printf("[PSK] Found portnum inside nested: 0x%02X (%d) at offset %d\n", 
                             portnum, portnum, pos);
                
                // Look for 0x12 (payload) after portnum
                if (pos + 2 < searchEnd && decrypted[pos + 2] == 0x12) {
                  uint32_t payloadLen = 0;
                  size_t payloadVarintBytes = 0;
                  
                  if (decodeVarint(pos + 3, payloadLen, payloadVarintBytes)) {
                    size_t payloadStart = pos + 3 + payloadVarintBytes;
                    Serial.printf("[PSK] Found payload at %d, len=%d (varint=%d bytes)\n", 
                                 pos + 2, payloadLen, payloadVarintBytes);
                    
                    // Look for 0x0A (text field) inside payload
                    if (payloadStart < searchEnd && payloadLen > 0) {
                      size_t payloadEnd = min((size_t)(payloadStart + payloadLen), searchEnd);
                      
                      for (size_t textPos = payloadStart; textPos < payloadEnd - 2; textPos++) {
                        if (decrypted[textPos] == 0x0A) {
                          uint32_t textLen = 0;
                          size_t textVarintBytes = 0;
                          
                          if (decodeVarint(textPos + 1, textLen, textVarintBytes)) {
                            size_t textStart = textPos + 1 + textVarintBytes;
                            Serial.printf("[PSK] Found text field at %d, len=%d (varint=%d bytes)\n",
                                         textPos, textLen, textVarintBytes);
                            
                            if (textLen > 0 && textLen <= 250 && (textStart + textLen) <= searchEnd) {
                              String text = "";
                              bool validText = true;
                              
                              for (uint32_t i = 0; i < textLen; i++) {
                                uint8_t c = decrypted[textStart + i];
                                if (c >= 32 && c <= 126) {
                                  text += (char)c;
                                } else if (c == 0x0A || c == 0x0D) {
                                  text += '\n';
                                } else if (c == 0) {
                                  break;
                                } else {
                                  validText = false;
                                  break;
                                }
                              }
                              
                              if (validText && text.length() >= 1) {
                                messageText = text;
                                foundTextMessage = true;
                                Serial.printf("[PSK] ✅ EXTRACTED TEXT FROM NESTED MESSAGE: \"%s\"\n", 
                                             messageText.c_str());
                                break;
                              }
                            }
                          }
                        }
                      }
                    }
                    
                    if (foundTextMessage) break;
                  }
                }
              }
            }
          }
        }
      }
      
      // Search for portnum field (0x08) followed by TEXT_MESSAGE_APP (0x01)
      // ANYWHERE in the decrypted data, not just at the start!
      Serial.println("[PSK] 🔍 Comprehensive search for text message patterns...");
      
      for (size_t pos = 0; pos < encryptedLen - 5; pos++) {
        // Pattern: 0x08 0x01 (portnum=TEXT_MESSAGE_APP)
        if (decrypted[pos] == 0x08 && decrypted[pos + 1] == 0x01) {
          Serial.printf("[PSK] ✓✓✓ FOUND TEXT_MESSAGE_APP (0x08 0x01) at offset %d!\n", pos);
          
          // Next should be 0x12 (payload field)
          if (pos + 2 < encryptedLen && decrypted[pos + 2] == 0x12) {
            uint8_t payloadLen = decrypted[pos + 3];
            Serial.printf("[PSK] Payload field found, length=%d\n", payloadLen);
            
            // Inside payload, look for 0x0A (text field, wire type 2)
            size_t payloadStart = pos + 4;
            if (payloadStart < encryptedLen && decrypted[payloadStart] == 0x0A) {
              uint8_t textLen = decrypted[payloadStart + 1];
              Serial.printf("[PSK] Text field found, length=%d\n", textLen);
              
              // Extract text
              if (textLen > 0 && textLen < 80 && (payloadStart + 2 + textLen) <= encryptedLen) {
                String text = "";
                bool validText = true;
                
                for (uint8_t i = 0; i < textLen; i++) {
                  uint8_t c = decrypted[payloadStart + 2 + i];
                  if (c >= 32 && c <= 126) {  // Printable ASCII
                    text += (char)c;
                  } else if (c == 0x0A || c == 0x0D) {  // Allow newlines
                    text += '\n';
                  } else if (c == 0) {
                    break;  // Null terminator
                  } else {
                    // Non-printable character
                    validText = false;
                    break;
                  }
                }
                
                if (validText && text.length() >= 1) {
                  messageText = text;
                  foundTextMessage = true;
                  Serial.printf("[PSK] 📧 DECRYPTED TEXT MESSAGE: \"%s\"\n", messageText.c_str());
                  break;
                }
              }
            }
          }
        }
      }
      
      // Alternative: Look for 0x12 (payload field) with varint length decoding
      if (!foundTextMessage) {
        Serial.println("[PSK] Trying alternative protobuf parsing...");
        
        // Use the varint decoder already defined above
        
        for (size_t pos = 0; pos < encryptedLen - 4; pos++) {
          // Look for: 0x12 (payload field)
          if (decrypted[pos] == 0x12 && pos + 1 < encryptedLen) {
            uint32_t payloadLen = 0;
            size_t varintBytes = 0;
            
            // Decode varint length
            if (decodeVarint(pos + 1, payloadLen, varintBytes)) {
              size_t payloadStart = pos + 1 + varintBytes;
              Serial.printf("[PSK] Found 0x12 (payload) at %d, len=%d (varint=%d bytes)\n", 
                           pos, payloadLen, varintBytes);
              
              // Now look for 0x0A (text field) inside the payload
              if (payloadStart < encryptedLen && payloadLen > 2) {
                size_t searchEnd = min((size_t)(payloadStart + payloadLen), encryptedLen);
                
                for (size_t textPos = payloadStart; textPos < searchEnd - 2; textPos++) {
                  if (decrypted[textPos] == 0x0A) {
                    uint32_t textLen = 0;
                    size_t textVarintBytes = 0;
                    
                    // Decode text length as varint
                    if (decodeVarint(textPos + 1, textLen, textVarintBytes)) {
                      size_t textStart = textPos + 1 + textVarintBytes;
                      Serial.printf("[PSK] Found 0x0A (text) at %d, len=%d (varint=%d bytes)\n",
                                   textPos, textLen, textVarintBytes);
                      
                      if (textLen > 0 && textLen <= 250 && (textStart + textLen) <= encryptedLen) {
                        String text = "";
                        bool validText = true;
                        
                        for (uint32_t i = 0; i < textLen; i++) {
                          uint8_t c = decrypted[textStart + i];
                          if (c >= 32 && c <= 126) {
                            text += (char)c;
                          } else if (c == 0x0A || c == 0x0D) {
                            text += '\n';
                          } else if (c == 0) {
                            break;
                          } else {
                            validText = false;
                            break;
                          }
                        }
                        
                        if (validText && text.length() >= 3) {  // At least 3 chars
                          messageText = text;
                          foundTextMessage = true;
                          Serial.printf("[PSK] 📧 DECRYPTED TEXT MESSAGE: \"%s\"\n", messageText.c_str());
                          break;
                        }
                      }
                    }
                  }
                }
              }
              
              if (foundTextMessage) break;
            }
          }
        }
      }
      
      // Last fallback: search for any continuous readable text (DISABLED - causes watchdog timeout)
      if (!foundTextMessage) {
        Serial.println("[PSK] No text extraction patterns matched");
      }
      
      if (!foundTextMessage) {
        // Display raw decrypted content with ASCII interpretation
        Serial.print("[PSK] 🔍 Decrypted content: ");
        for (size_t j = 0; j < min(encryptedLen, size_t(64)); j++) {
          if (decrypted[j] >= 32 && decrypted[j] <= 126) {
            Serial.printf("'%c' ", decrypted[j]);
          } else {
            Serial.printf("0x%02X ", decrypted[j]);
          }
        }
        Serial.println();
        
        // For larger packets (potential text messages), show full hex
        if (encryptedLen >= 80) {
          Serial.println("[PSK] 📊 FULL DECRYPTED HEX:");
          for (size_t j = 0; j < encryptedLen; j++) {
            Serial.printf("%02X ", decrypted[j]);
            if ((j + 1) % 16 == 0) Serial.print("\n[PSK]   ");
          }
          Serial.println();
        }
        
        // Try to identify message type
        if (encryptedLen < 32) {
          Serial.println("[PSK] >>> DECRYPTED CONTROL/ROUTING MESSAGE <<<");
        } else {
          Serial.println("[PSK] >>> DECRYPTED DATA MESSAGE (non-text) <<<");
        }
      } else {
        Serial.println("[PSK] >>> 🎯 USER TEXT MESSAGE SUCCESSFULLY DECRYPTED! <<<");
      }
      
      Serial.printf("[PSK] Key used: \"%s\" (Default key #%d)\n", defaultPSKs[i], i + 1);
      Serial.println("[PSK] === END DECRYPTION ANALYSIS ===");
      
      return true;
    }
  }
  
  return false;
}

void PSKDecryption::initialize() {
  Serial.println("🔐 PSK Testing module initialized");
  Serial.printf("📊 Loaded %d default Meshtastic PSKs\n", NUM_DEFAULT_PSKS);
}

PSKStats PSKDecryption::getStats() {
  return pskStats;
}

void PSKDecryption::resetStats() {
  pskStats = PSKStats();  // Use constructor instead of memset
}

void PSKDecryption::printStats() {
  Serial.println("📊 PSK DECRYPTION STATISTICS:");
  Serial.printf("   Total Attempts: %d\n", pskStats.attempts);
  Serial.printf("   Successful: %d (%.1f%% success rate)\n", 
                pskStats.successes,
                pskStats.attempts > 0 ? (float)pskStats.successes / pskStats.attempts * 100.0 : 0.0);
  
  Serial.println("   PSK Hit Count:");
  for (uint8_t i = 0; i < NUM_DEFAULT_PSKS; i++) {
    if (pskStats.hitCount[i] > 0) {
      Serial.printf("     PSK #%d: %d hits\n", i + 1, pskStats.hitCount[i]);
    }
  }
  Serial.println();
}

