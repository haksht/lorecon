            case 0x43: Serial.println("(NEIGHBORINFO_APP) 👥"); break;
            case 0x44: Serial.println("(ATAK_PLUGIN) 🎖️"); break;
            // Note: PRIVATE_APP (0x101) and ATAK_FORWARDER (0x102) are varint-encoded in protobuf
            default: Serial.printf("(UNKNOWN/CUSTOM - decimal:%d)\n", portnum); break;
          }
          break;
        }
      }
      
      if (!foundPortnum) {
        Serial.println("[PSK] ⚠️  No portnum field (0x08) found in decrypted data");
        Serial.println();
        Serial.println("[PSK] ═══ ENHANCED DIAGNOSTIC OUTPUT ═══");
        Serial.println("[PSK] Firmware: v2.6.11 format analysis");
        Serial.println();
        
        // Deep analysis of decrypted structure
        Serial.println("[PSK] Byte-by-byte analysis (first 32 bytes):");
        for (size_t i = 0; i < min(encryptedLen, size_t(32)); i++) {
          Serial.printf("[PSK] [%2d] 0x%02X (%3d) ", i, decrypted[i], decrypted[i]);
          
          // Show as ASCII if printable
          if (decrypted[i] >= 32 && decrypted[i] <= 126) {
            Serial.printf("'%c' ", decrypted[i]);
          } else {
            Serial.print("    ");
          }
          
          // Protobuf field analysis
          uint8_t fieldNum = (decrypted[i] >> 3);
          uint8_t wireType = (decrypted[i] & 0x07);
          
          if (fieldNum > 0 && fieldNum <= 15 && wireType <= 5) {
            Serial.printf("→ Field:%d Wire:%d", fieldNum, wireType);
          }
          
          Serial.println();
        }
        
        Serial.println();
        Serial.println("[PSK] Pattern search:");
        
        // Look for common protobuf patterns
        bool found0x12 = false;
        bool found0x0A = false;
        
        for (size_t i = 0; i < encryptedLen; i++) {
          if (decrypted[i] == 0x08 && i + 1 < encryptedLen) {
            Serial.printf("[PSK]   • Found 0x08 at offset %d (next: 0x%02X = portnum %d)\n", 
                         i, decrypted[i+1], decrypted[i+1]);
          }
          if (decrypted[i] == 0x12 && i + 1 < encryptedLen) {
            if (!found0x12) {
              Serial.printf("[PSK]   • Found 0x12 at offset %d (payload field, len=%d)\n", 
                           i, decrypted[i+1]);
              found0x12 = true;
            }
          }
          if (decrypted[i] == 0x0A && i + 1 < encryptedLen) {
            if (!found0x0A) {
              Serial.printf("[PSK]   • Found 0x0A at offset %d (text field?, len=%d)\n", 
                           i, decrypted[i+1]);
              found0x0A = true;
            }
          }
        }
        
        // Check for ASCII text anywhere (might be unstructured)
        Serial.println();
        Serial.println("[PSK] ASCII text search:");
        String foundText = "";
        int textStart = -1;
        
        for (size_t i = 0; i < encryptedLen; i++) {
          if (decrypted[i] >= 32 && decrypted[i] <= 126) {
            if (textStart == -1) textStart = i;
            foundText += (char)decrypted[i];
          } else {
            if (foundText.length() >= 3) {
              Serial.printf("[PSK]   • ASCII string at offset %d: \"%s\"\n", 
                           textStart, foundText.c_str());
            }
            foundText = "";
            textStart = -1;
