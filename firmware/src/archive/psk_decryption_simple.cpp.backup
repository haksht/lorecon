/**
 * PSK Decryption - Cleaned and Refactored Version
 * 
 * This is a cleaned-up version of the PSK decryption code with:
 * - Modular text extraction functions
 * - Clear separation of concerns
 * - Reduced verbosity in diagnostics
 * - Better structure for adding format variants
 * 
 * IMPORTANT: The decryption works correctly. The issue is the message format
 * used by your specific Meshtastic firmware doesn't match the documented structure.
 */

#include "psk_decryption_simple.h"

#ifdef ENABLE_PSK_TESTING

#include <mbedtls/aes.h>
#include <mbedtls/base64.h>
#include "data_structures.h"

// Known Meshtastic default PSKs
const char* defaultPSKs[] = {
  "AQ==",                      // #1: LongFast default (YOUR DEVICES)
  "1PG7OiApB1nwvP+rz05pAQ==",  // #2: Common default
  "d1iq21lNSh7BP6MOkP6cQA==",  // #3: Channel 1
  "2f8aH6iT8K9jQ1P3mD4nBw==",  // #4: Channel 2
  "7h3kL9mR5wX2pY8qE6tZcA==",  // #5: Channel 3
};

const uint8_t NUM_DEFAULT_PSKS = sizeof(defaultPSKs) / sizeof(char*);

// PSK stats instance
PSKStats pskStats;

// Varint decoder utility
static bool decodeVarint(const uint8_t* data, size_t dataLen, size_t pos, uint32_t& value, size_t& bytesRead) {
    value = 0;
    bytesRead = 0;
    uint32_t shift = 0;
    
    while (pos + bytesRead < dataLen && bytesRead < 5) {
        uint8_t byte = data[pos + bytesRead];
        value |= ((uint32_t)(byte & 0x7F)) << shift;
        bytesRead++;
        if ((byte & 0x80) == 0) return true;
        shift += 7;
    }
    return false;
}

// Forward declarations for text extraction strategies
static bool extractTextStandard(const uint8_t* data, size_t len, String& text);
static bool extractTextImplicitPortnum(const uint8_t* data, size_t len, String& text);
static bool extractTextProtoWalker(const uint8_t* data, size_t len, String& text, String& path);
static void identifyPacketType(const uint8_t* data, size_t len);

void initializePSKStats() {
    pskStats = PSKStats();
}

int PSKDecryption::decodeBase64(const char* input, uint8_t* output, size_t maxLen) {
    size_t outLen = 0;
    int result = mbedtls_base64_decode(output, maxLen, &outLen,
                                       (const unsigned char*)input, strlen(input));
    if (result != 0 || outLen == 0) return 0;
    return (int)outLen; // number of bytes written
}

bool PSKDecryption::testDefaultPSKs(const uint8_t* data, size_t length) {
    pskStats.attempts++;
    
    // Validate packet structure
    if (length < 20) {
        Serial.println("[PSK] Packet too short for encrypted content");
        return false;
    }
    
    // Check if this has the 0xFFFFFFFF header or is a raw packet
    bool hasHeader = (data[0] == 0xFF && data[1] == 0xFF && data[2] == 0xFF && data[3] == 0xFF);
    size_t headerOffset = hasHeader ? 0 : 0;  // Might need to detect raw packet structure
    
    uint32_t nodeId, packetId;
    uint8_t packetType;
    const uint8_t* encryptedData;
    size_t encryptedLen;
    
    if (hasHeader) {
        // Standard Meshtastic packet with 0xFFFFFFFF header
        nodeId = (uint32_t(data[4]) << 24) | (uint32_t(data[5]) << 16) | 
                 (uint32_t(data[6]) << 8) | uint32_t(data[7]);
        packetType = data[8];
        packetId = ((uint32_t)data[10]) | ((uint32_t)data[11] << 8) | 
                   ((uint32_t)data[12] << 16) | ((uint32_t)data[13] << 24);
        encryptedData = data + 14;
        encryptedLen = length - 14;
        
        Serial.println("\n[PSK] === STANDARD PACKET (with 0xFFFFFFFF header) ===");
    } else {
        // Raw packet without header - try to parse directly
        // Format appears to be: dest(4) src(4) type(1) flags(1) packetId(4) encrypted...
        if (length < 14) {
            Serial.println("[PSK] Raw packet too short");
            return false;
        }
        
        // Try parsing as raw Meshtastic packet
        nodeId = (uint32_t(data[4]) << 24) | (uint32_t(data[5]) << 16) | 
                 (uint32_t(data[6]) << 8) | uint32_t(data[7]);  // Source node
        packetType = data[8];
        packetId = ((uint32_t)data[10]) | ((uint32_t)data[11] << 8) | 
                   ((uint32_t)data[12] << 16) | ((uint32_t)data[13] << 24);
        encryptedData = data + 14;
        encryptedLen = length - 14;
        
        Serial.println("\n[PSK] === RAW PACKET (no 0xFFFFFFFF header) ===");
        Serial.print("[PSK] First 16 bytes: ");
        for (size_t j = 0; j < min(length, size_t(16)); j++) {
            Serial.printf("%02X ", data[j]);
        }
        Serial.println();
    }
    
    // Prefer data packets (type nibble 0x1) but continue with others for analysis
    uint8_t typeNibble = packetType & 0x0F;
    if (typeNibble != 0x01) {
        Serial.printf("[PSK] рџ”Ћ Non-data packet type 0x%02X (nibble 0x%X) - attempting decrypt for discovery\n",
                      packetType, typeNibble);
    } else {
        Serial.println("\n[PSK] === рџЋЇ DATA PACKET DETECTED - ATTEMPTING DECRYPTION ===");
    }
    Serial.printf("[PSK] Node: 0x%08X, Type: 0x%02X, Packet ID: 0x%08X\n", nodeId, packetType, packetId);
    
    // Print encrypted payload to see if text is visible before decryption
    if (encryptedLen >= 20) {
        Serial.print("[PSK] Encrypted payload (first 40 bytes): ");
        for (size_t j = 0; j < min(encryptedLen, size_t(40)); j++) {
            Serial.printf("%02X ", encryptedData[j]);
            if ((j + 1) % 20 == 0) Serial.print("\n                                          ");
        }
        Serial.println();
        
        // CHECK IF PACKET IS ACTUALLY UNENCRYPTED!
        if (encryptedData[0] == 0x08 || encryptedData[1] == 0x08 || encryptedData[2] == 0x08) {
            Serial.println("[PSK] вљ пёЏвљ пёЏвљ пёЏ PACKET APPEARS TO BE UNENCRYPTED! (Found 0x08 field marker)");
            Serial.println("[PSK] Analyzing as plaintext protobuf...");
            
            // Try to extract text directly from "encrypted" data
            for (size_t searchPos = 0; searchPos < encryptedLen - 5; searchPos++) {
                if (encryptedData[searchPos] == 0x08) {
                    uint8_t portnum = encryptedData[searchPos + 1];
                    Serial.printf("[PSK] Found Field 1 at offset %d, portnum = 0x%02X", searchPos, portnum);
                    
                    if (portnum == 0x01) {
                        Serial.println(" (TEXT_MESSAGE_APP!) рџ“§");
                        // Look for text after 0x12 (Field 2)
                        if (searchPos + 2 < encryptedLen && encryptedData[searchPos + 2] == 0x12) {
                            uint32_t payloadLen = 0;
                            size_t varintBytes = 0;
                            if (decodeVarint(encryptedData, encryptedLen, searchPos + 3, payloadLen, varintBytes)) {
                                size_t payloadStart = searchPos + 3 + varintBytes;
                                if (payloadStart < encryptedLen && encryptedData[payloadStart] == 0x0A) {
                                    uint32_t textLen = 0;
                                    size_t textVarintBytes = 0;
                                    if (decodeVarint(encryptedData, encryptedLen, payloadStart + 1, textLen, textVarintBytes)) {
                                        size_t textStart = payloadStart + 1 + textVarintBytes;
                                        if (textStart < encryptedLen && textLen > 0 && textLen < 200) {
                                            Serial.print("\nрџЋ‰рџЋ‰рџЋ‰ PLAINTEXT MESSAGE FOUND: \"");
                                            for (uint32_t i = 0; i < textLen && (textStart + i) < encryptedLen; i++) {
                                                char c = encryptedData[textStart + i];
                                                if (c >= 32 && c <= 126) Serial.print(c);
                                                else Serial.printf("<%02X>", c);
                                            }
                                            Serial.println("\" рџЋ‰рџЋ‰рџЋ‰\n");
                                            return true;  // Don't try to decrypt - it's plaintext!
                                        }
                                    }
                                }
                            }
                        }
                    } else if (portnum == 0x03) {
                        Serial.println(" (POSITION_APP)");
                    } else {
                        Serial.printf(" (Unknown app)\n");
                    }
                }
            }
        }
    }
    
    // Try each default PSK
    for (uint8_t i = 0; i < NUM_DEFAULT_PSKS; i++) {
        uint8_t key[32];  // Enough space for AES-256 if needed
        int keyLen = decodeBase64(defaultPSKs[i], key, sizeof(key));

        if (keyLen != 16 && keyLen != 1) {  // Meshtastic pads single-byte keys to 16 bytes
            Serial.printf("[PSK] вљ пёЏ Skipping PSK #%d \"%s\": decoded length %d bytes (expect 1 or 16)\n",
                          i + 1, defaultPSKs[i], keyLen);
            continue;
        }

        uint8_t expandedKey[16];
        if (keyLen == 16) {
            memcpy(expandedKey, key, 16);
        } else {
            memset(expandedKey, key[0], sizeof(expandedKey));
            Serial.printf("[PSK]    Single-byte PSK detected, expanding 0x%02X to 16 bytes\n", key[0]);
        }

        // Debug: Print decoded/expanded key
        Serial.printf("[PSK] рџ”‘ Trying PSK #%d \"%s\"\n", i + 1, defaultPSKs[i]);
        Serial.print("[PSK]    Key (hex): ");
        for (int k = 0; k < 16; k++) Serial.printf("%02X", expandedKey[k]);
        Serial.println();
        
        // Construct AES-CTR nonce (double-check ordering for your firmware)
        uint8_t nonce[16];
        memset(nonce, 0, sizeof(nonce));
        nonce[0] = (packetId) & 0xFF;
        nonce[1] = (packetId >> 8) & 0xFF;
        nonce[2] = (packetId >> 16) & 0xFF;
        nonce[3] = (packetId >> 24) & 0xFF;
        
        // Node ID goes in nonce[8..11] - use appropriate offset based on packet format
        if (hasHeader) {
            nonce[8] = data[4];
            nonce[9] = data[5];
            nonce[10] = data[6];
            nonce[11] = data[7];
        } else {
            // For raw packets, node ID is at offset 4-7
            nonce[8] = data[4];
            nonce[9] = data[5];
            nonce[10] = data[6];
            nonce[11] = data[7];
        }
        
        // Debug: Print nonce
        Serial.print("[PSK]    Nonce (hex): ");
        for (int k = 0; k < 16; k++) Serial.printf("%02X", nonce[k]);
        Serial.println();
        
        // Check buffer size to prevent overflow
        uint8_t decrypted[256];
        if (encryptedLen > sizeof(decrypted)) {
            Serial.printf("[PSK] вљ пёЏ Packet too large (%u bytes) for local buffer (%u)\n", 
                          (unsigned)encryptedLen, (unsigned)sizeof(decrypted));
            continue;
        }
        
        // Decrypt with AES-CTR
        mbedtls_aes_context aes;
        mbedtls_aes_init(&aes);
        
        if (mbedtls_aes_setkey_enc(&aes, expandedKey, 128) != 0) {
            mbedtls_aes_free(&aes);
            Serial.printf("[PSK] вќЊ Failed to set AES key for PSK #%d\n", i + 1);
            continue;
        }
        
        // Proper AES-CTR usage: separate nonce_counter and stream_block
        uint8_t nonce_counter[16];
        uint8_t stream_block[16];
        memcpy(nonce_counter, nonce, 16);
        memset(stream_block, 0, 16);
        size_t nc_off = 0;
        
        int result = mbedtls_aes_crypt_ctr(&aes, encryptedLen, &nc_off,
                                           nonce_counter, stream_block,
                                           encryptedData, decrypted);
        mbedtls_aes_free(&aes);
        
        if (result != 0) {
            Serial.printf("[PSK] вќЊ AES CTR decrypt failed for PSK #%d (err=%d)\n", i + 1, result);
            continue;
        }
        
        // Validate decryption (basic protobuf check)
        uint8_t firstByte = decrypted[0];
        uint8_t fieldNum = firstByte >> 3;
        uint8_t wireType = firstByte & 0x07;
        
        bool looksValid = (fieldNum >= 1 && fieldNum <= 31 && wireType <= 5);
        
        if (!looksValid) {
            continue;  // Skip invalid decryptions
        }
        
        // Successfully decrypted
        pskStats.successes++;
        pskStats.hitCount[i]++;
        
        Serial.printf("[PSK] вњ“ Decryption SUCCESS with key #%d: \"%s\"\n", i + 1, defaultPSKs[i]);
        Serial.print("[PSK] First 32 bytes: ");
        for (size_t j = 0; j < min(encryptedLen, size_t(32)); j++) {
            Serial.printf("%02X ", decrypted[j]);
        }
        Serial.println();
        
        // For large packets, also print full decrypted data to find patterns (first 160 bytes)
        if (encryptedLen > 50) {
            Serial.print("[PSK] Full decrypted data: ");
            size_t maxDump = min(encryptedLen, size_t(160));
            for (size_t j = 0; j < maxDump; j++) {
                Serial.printf("%02X ", decrypted[j]);
                if ((j + 1) % 20 == 0) Serial.print("\n                            ");
            }
            if (encryptedLen > maxDump) {
                Serial.print("... (truncated)");
            }
            Serial.println();
        }

        // Provide Base64 representation for offline decoding/analysis
        char base64Buffer[512];
        size_t base64Len = 0;
        int b64Result = mbedtls_base64_encode(reinterpret_cast<unsigned char*>(base64Buffer),
                                              sizeof(base64Buffer) - 1,
                                              &base64Len,
                                              decrypted,
                                              encryptedLen);
        if (b64Result == 0 && base64Len > 0 && base64Len < sizeof(base64Buffer)) {
            base64Buffer[base64Len] = '\0';
            Serial.printf("[PSK] Decrypted payload (Base64, %u bytes): %s\n",
                          (unsigned)encryptedLen, base64Buffer);
        } else {
            Serial.printf("[PSK] вљ пёЏ Base64 encode failed (err=%d, len=%u)\n",
                          b64Result, (unsigned)encryptedLen);
        }
        
        // Identify packet type
        identifyPacketType(decrypted, encryptedLen);
        
        // SEARCH FOR STRUCTURED TEXT IN DECRYPTED DATA
        Serial.println("[PSK] рџ”Ќ Evaluating protobuf structure for text fields...");
        String extractedText = "";
        bool foundText = false;
        String protoWalkerPath = "";
        
        // Strategy 1: Standard protobuf format (0x08 0x01 0x12 ... 0x0A)
        if (extractTextStandard(decrypted, encryptedLen, extractedText)) {
            foundText = true;
            Serial.println("[PSK] вњ“ Text extraction: STANDARD FORMAT");
        }
        // Strategy 1b: Portnum 0x24 (custom/extended message type)
        else if (decrypted[0] == 0x08 && decrypted[1] == 0x24) {
            Serial.println("[PSK] рџЋЇ PORTNUM 0x24 DETECTED - Trying to extract text...");
            // Same structure as standard, just different portnum
            if (decrypted[2] == 0x12) {
                uint32_t payloadLen = 0;
                size_t varintBytes = 0;
                if (decodeVarint(decrypted, encryptedLen, 3, payloadLen, varintBytes)) {
                    size_t payloadStart = 3 + varintBytes;
                    if (payloadStart < encryptedLen && decrypted[payloadStart] == 0x0A) {
                        uint32_t textLen = 0;
                        size_t textVarintBytes = 0;
                        if (decodeVarint(decrypted, encryptedLen, payloadStart + 1, textLen, textVarintBytes)) {
                            size_t textStart = payloadStart + 1 + textVarintBytes;
                            if (textStart < encryptedLen && textLen > 0 && textLen < 200) {
                                for (uint32_t i = 0; i < textLen && (textStart + i) < encryptedLen; i++) {
                                    uint8_t c = decrypted[textStart + i];
                                    if (c >= 32 && c <= 126) {
                                        extractedText += (char)c;
                                    } else if (c == 0) break;
                                }
                                if (extractedText.length() > 0) {
                                    foundText = true;
                                    Serial.println("[PSK] вњ“ Text extraction: PORTNUM 0x24 FORMAT");
                                }
                            }
                        }
                    }
                }
            }
        }
        // Strategy 2: Implicit portnum (starts with 0x12)
        else if (extractTextImplicitPortnum(decrypted, encryptedLen, extractedText)) {
            foundText = true;
            Serial.println("[PSK] вњ“ Text extraction: IMPLICIT PORTNUM FORMAT");
        }
        // Strategy 3: Deep protobuf walk (nested fields)
        else if (extractTextProtoWalker(decrypted, encryptedLen, extractedText, protoWalkerPath)) {
            foundText = true;
            Serial.printf("[PSK] рџ”Ћ Text extraction: PROTO WALKER (path %s)\n", protoWalkerPath.c_str());
        }
        if (foundText && extractedText.length() >= 2) {
            Serial.println("\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—");
            Serial.printf("в•‘  рџ“§ TEXT MESSAGE: \"%s\"\n", extractedText.c_str());
            Serial.println("в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n");
        }
        
        if (!foundText) {
            Serial.println("[PSK] в„№пёЏ No text message found (packet likely routing/position/admin)");
        }
        
        return true;
    }
    
    return false;
}

/**
 * Strategy 1: Extract text from standard Meshtastic protobuf format
 * Expected structure: 0x08 0x01 0x12 <len> 0x0A <textlen> <TEXT>
 */
static bool extractTextStandard(const uint8_t* data, size_t len, String& text) {
    if (len < 6) return false;
    
    // Look for: Field 1 (portnum) = TEXT_MESSAGE_APP (0x01)
    if (data[0] != 0x08 || data[1] != 0x01) {
        return false;
    }
    
    // Next should be Field 2 (payload)
    if (data[2] != 0x12) {
        return false;
    }
    
    uint32_t payloadLen = 0;
    size_t varintBytes = 0;
    if (!decodeVarint(data, len, 3, payloadLen, varintBytes)) {
        return false;
    }
    
    size_t payloadStart = 3 + varintBytes;
    if (payloadStart >= len || payloadLen == 0) {
        return false;
    }
    
    // Look for text field (0x0A) inside payload
    if (data[payloadStart] != 0x0A) {
        return false;
    }
    
    uint32_t textLen = 0;
    size_t textVarintBytes = 0;
    if (!decodeVarint(data, len, payloadStart + 1, textLen, textVarintBytes)) {
        return false;
    }
    
    size_t textStart = payloadStart + 1 + textVarintBytes;
    if (textStart >= len || textLen == 0 || textLen > 200) {
        return false;
    }
    
    // Extract text
    for (uint32_t i = 0; i < textLen && (textStart + i) < len; i++) {
        uint8_t c = data[textStart + i];
        if (c >= 32 && c <= 126) {
            text += (char)c;
        } else if (c == 0x0A || c == 0x0D) {
            text += '\n';
        } else if (c == 0) {
            break;
        } else {
            return false;  // Invalid text character
        }
    }
    
    return (text.length() >= 1);
}

/**
 * Strategy 2: Extract text from implicit portnum format
 * Some firmware versions omit the portnum field for common types
 * Expected structure: 0x12 <len> 0x0A <textlen> <TEXT>
 */
static bool extractTextImplicitPortnum(const uint8_t* data, size_t len, String& text) {
    if (len < 5) return false;
    
    // Starts with Field 2 (payload) - implicit portnum
    if (data[0] != 0x12) {
        return false;
    }
    
    uint32_t payloadLen = 0;
    size_t varintBytes = 0;
    if (!decodeVarint(data, len, 1, payloadLen, varintBytes)) {
        return false;
    }
    
    size_t payloadStart = 1 + varintBytes;
    if (payloadStart >= len || payloadLen == 0) {
        return false;
    }
    
    // Look for text field (0x0A)
    if (data[payloadStart] != 0x0A) {
        return false;
    }
    
    uint32_t textLen = 0;
    size_t textVarintBytes = 0;
    if (!decodeVarint(data, len, payloadStart + 1, textLen, textVarintBytes)) {
        return false;
    }
    
    size_t textStart = payloadStart + 1 + textVarintBytes;
    if (textStart >= len || textLen == 0 || textLen > 200) {
        return false;
    }
    
    // Extract text
    for (uint32_t i = 0; i < textLen && (textStart + i) < len; i++) {
        uint8_t c = data[textStart + i];
        if (c >= 32 && c <= 126) {
            text += (char)c;
        } else if (c == 0x0A || c == 0x0D) {
            text += '\n';
        } else if (c == 0) {
            break;
        } else {
            return false;
        }
    }
    
    return (text.length() >= 1);
}

// === Protobuf field walker ==================================================
struct ProtoWalkerResult {
    String bestText;
    String bestPath;
    bool found = false;
    size_t bestScore = 0;
};

static bool isLikelyPrintable(const uint8_t* data, size_t len, size_t& printable, size_t& controlChars) {
    printable = 0;
    controlChars = 0;
    if (len == 0 || len > 256) return false;

    for (size_t i = 0; i < len; i++) {
        uint8_t c = data[i];
        if (c >= 32 && c <= 126) {
            printable++;
        } else if (c == '\n' || c == '\r' || c == '\t') {
            controlChars++;
        } else if (c == 0) {
            controlChars++;
        }
    }

    size_t effective = printable + controlChars;
    if (effective == 0) return false;

    float ratio = (float)(printable + controlChars) / (float)len;
    return (printable >= 4 && ratio >= 0.75f);
}

static void walkProtobuf(const uint8_t* data, size_t len, const String& path,
                         uint8_t depth, ProtoWalkerResult& result) {
    if (depth > 6 || len < 2) return;

    size_t pos = 0;
    while (pos < len) {
        uint32_t key = 0;
        size_t keyBytes = 0;
        if (!decodeVarint(data, len, pos, key, keyBytes)) {
            return;  // malformed
        }
        pos += keyBytes;

        uint32_t fieldNum = key >> 3;
        uint8_t wireType = key & 0x07;

        String fieldPath = path;
        if (fieldPath.length() > 0) fieldPath += ".";
        fieldPath += String(fieldNum);

        switch (wireType) {
            case 0: {  // varint
                uint32_t value = 0;
                size_t valueBytes = 0;
                if (!decodeVarint(data, len, pos, value, valueBytes)) {
                    return;
                }
                pos += valueBytes;
                break;
            }
            case 1: {  // 64-bit
                if (pos + 8 > len) return;
                pos += 8;
                break;
            }
            case 5: {  // 32-bit
                if (pos + 4 > len) return;
                pos += 4;
                break;
            }
            case 2: {  // length-delimited
                uint32_t subLen = 0;
                size_t lenBytes = 0;
                if (!decodeVarint(data, len, pos, subLen, lenBytes)) {
                    return;
                }
                pos += lenBytes;
                if (pos + subLen > len) {
                    return;
                }

                const uint8_t* segment = data + pos;
                size_t printable = 0;
                size_t controls = 0;
                bool looksPrintable = isLikelyPrintable(segment, subLen, printable, controls);
                if (depth <= 3 && subLen >= 4) {
                    Serial.printf("[PSK] рџ“‚ Proto field %s len=%u (printable=%u control=%u)\n",
                                  fieldPath.c_str(), (unsigned)subLen,
                                  (unsigned)printable, (unsigned)controls);
                }
                if (looksPrintable) {
                    String candidate = "";
                    candidate.reserve(subLen);
                    for (uint32_t i = 0; i < subLen; i++) {
                        uint8_t c = segment[i];
                        if (c >= 32 && c <= 126) {
                            candidate += (char)c;
                        } else if (c == '\n' || c == '\r') {
                            candidate += '\n';
                        } else if (c == '\t') {
                            candidate += ' ';
                        } else {
                            candidate += '?';
                        }
                    }

                    size_t score = printable + (controls / 2);
                    if (score > result.bestScore && candidate.length() >= 4) {
                        result.bestScore = score;
                        result.bestText = candidate;
                        result.bestPath = fieldPath;
                        result.found = true;
                        Serial.printf("[PSK] рџ§­ ProtoWalker found printable field at %s (len=%u, printable=%u)\n",
                                      fieldPath.c_str(), (unsigned)subLen, (unsigned)printable);
                    }
                }

                if (subLen >= 2 && depth < 6) {
                    walkProtobuf(segment, subLen, fieldPath, depth + 1, result);
                }

                pos += subLen;
                break;
            }
            case 3:  // start group (deprecated) - stop parsing to avoid infinite loop
            case 4:  // end group
            default:
                return;
        }
    }
}

static bool extractTextProtoWalker(const uint8_t* data, size_t len, String& text, String& path) {
    ProtoWalkerResult result;
    walkProtobuf(data, len, "", 0, result);
    if (result.found && result.bestText.length() > 0) {
        text = result.bestText;
        path = result.bestPath;
        return true;
    }
    return false;
}

/**
 * Identify the type of decrypted packet
 */
static void identifyPacketType(const uint8_t* data, size_t len) {
    if (len < 2) {
        Serial.println("[PSK] Type: UNKNOWN (too short)");
        return;
    }
    
    uint8_t firstByte = data[0];
    uint8_t fieldNum = firstByte >> 3;
    uint8_t wireType = firstByte & 0x07;
    
    Serial.printf("[PSK] First byte: 0x%02X (Field %u, Wire %u)\n", firstByte, fieldNum, wireType);
    
    // Check for explicit portnum field
    if (firstByte == 0x08 && len > 1) {
        uint8_t portnum = data[1];
        Serial.printf("[PSK] Type: ");
        switch(portnum) {
            case 0x01: Serial.println("TEXT_MESSAGE_APP вњ‰пёЏ"); break;
            case 0x03: Serial.println("POSITION_APP рџ“Ќ"); break;
            case 0x04: Serial.println("NODEINFO_APP в„№пёЏ"); break;
            case 0x07: Serial.println("ROUTING_APP рџ”„"); break;
            case 0x09: Serial.println("TEXT_MESSAGE_COMPRESSED_APP вњ‰пёЏрџ—њпёЏ"); break;
            default: Serial.printf("UNKNOWN APP (0x%02X)\n", portnum); break;
        }
    }
    // Check for implicit portnum (starts with payload field)
    else if (firstByte == 0x12) {
        Serial.println("[PSK] Type: POSITION_APP (implicit portnum=3) рџ“Ќ");
    }
    // Other patterns
    else {
        Serial.println("[PSK] Type: ROUTING/ADMIN/OTHER");
    }
}

void PSKDecryption::initialize() {
    Serial.println("рџ”ђ PSK Testing module initialized");
    Serial.printf("рџ“Љ Loaded %d default Meshtastic PSKs\n", NUM_DEFAULT_PSKS);
}

PSKStats PSKDecryption::getStats() {
    return pskStats;
}

void PSKDecryption::resetStats() {
    pskStats = PSKStats();
}

void PSKDecryption::printStats() {
    Serial.println("\nрџ“Љ PSK DECRYPTION STATISTICS:");
    Serial.printf("   Total Attempts: %d\n", pskStats.attempts);
    Serial.printf("   Successful: %d (%.1f%% success rate)\n", 
                  pskStats.successes,
                  pskStats.attempts > 0 ? (float)pskStats.successes / pskStats.attempts * 100.0 : 0.0);
    
    Serial.println("   PSK Hit Count:");
    for (uint8_t i = 0; i < NUM_DEFAULT_PSKS; i++) {
        if (pskStats.hitCount[i] > 0) {
            Serial.printf("     PSK #%d: %d hits\n", i + 1, pskStats.hitCount[i]);
        }
    }
    Serial.println();
}

#endif // ENABLE_PSK_TESTING
